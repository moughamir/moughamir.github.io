---
import Icon from "./Icon.astro";
const currentYear = new Date().getFullYear();

const socialLinks = [
  { label: "GitHub", href: "https://github.com/moughamir", icon: "github-logo" },
  { label: "LinkedIn", href: "https://linkedin.com/in/moughamir", icon: "linkedin-logo" },
  { label: "YouTube", href: "https://youtube.com/@moughamir", icon: "youtube-logo" },
  { label: "Podcast RSS", href: "/feed.xml", icon: "rss" },
  { label: "Email", href: "mailto:moughamir@gmail.com", icon: "mail" },
];
---

<footer>
  <div class="social-row" aria-label="Social links">
    {socialLinks.map(({ href, icon, label }) => (
      <a href={href} class="social-link" aria-label={label} target="_blank" rel="noopener noreferrer">
        <Icon icon={icon} size="1.25rem" />
      </a>
    ))}
  </div>
  <div class="footer-text">
    <p>Designed and built in Bouskoura with <a href="https://astro.build/">Astro</a>. Deployed on Vercel.</p>
    <p>&copy; {currentYear} Mohamed Moughamir — Available for remote EMEA work</p>
  </div>
</footer>

<style>
  footer {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    justify-content: space-between;
    padding: 2rem 1.25rem;
    color: var(--gray-500);
    font-size: 0.92rem;
  }

  .social-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.45rem;
    color: var(--gray-500);
    text-decoration: none;
    transition: color 160ms ease, background 160ms ease;
  }

  .social-link:hover {
    color: var(--gray-0);
    background: var(--gray-950);
  }

  .footer-text {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  a {
    color: var(--gray-0);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  @media (min-width: 50em) {
    footer {
      flex-direction: row;
      align-items: center;
      padding: 2.5rem 5rem;
    }
  }
</style>
