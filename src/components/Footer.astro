---
import Icon from "./Icon.astro";
const currentYear = new Date().getFullYear();

const socialLinks = [
  { label: "GitHub", href: "https://github.com/moughamir", icon: "github-logo" },
  { label: "LinkedIn", href: "https://linkedin.com/in/moughamir", icon: "linkedin-logo" },
  { label: "YouTube", href: "https://youtube.com/@moughamir", icon: "youtube-logo" },
  { label: "Podcast", href: "https://open.spotify.com/show/7EmRYqAIgMjQroosj2LV95", icon: "rss" },
  { label: "Email", href: "javascript:void(0)", icon: "mail", encoded: "bW91Z2hhbWlyQGdtYWlsLmNvbQ==" },
];
---

<footer>
  <div class="social-row" aria-label="Social links">
    {socialLinks.map(({ href, icon, label, encoded }) => {
      const extra = encoded ? { "data-email": encoded, onclick: "location.href='mailto:'+atob(this.dataset.email)" } : {};
      return <a href={href} class="social-link" aria-label={label} target="_blank" rel="noopener noreferrer" {...extra}>
        <Icon icon={icon} size="1.25rem" />
      </a>;
    })}
  </div>
  <div class="footer-text">
    <p>Designed and built in Bouskoura with <a href="https://astro.build/">Astro</a>. Deployed on GitHub Pages.</p>
    <p>&copy; {currentYear} Mohamed Moughamir — Available for remote EMEA work</p>
  </div>
</footer>

<style>
  footer {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    padding: 4rem 0;
    margin-top: 5rem;
    border-top: 2px solid var(--gray-0);
    font-family: var(--font-body);
  }

  .social-row {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--gray-0);
    text-decoration: none;
    transition: transform 0.1s, color 0.1s;
  }

  .social-link:hover {
    color: var(--accent-regular);
    transform: translateY(-4px);
  }

  .footer-text {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    font-weight: 500;
  }

  .footer-text p {
    color: var(--gray-200);
    margin: 0;
  }

  a {
    color: var(--gray-0);
    text-decoration: underline;
    text-underline-offset: 0.2em;
    font-weight: 700;
  }

  a:hover {
    color: var(--accent-regular);
  }

  @media (min-width: 50em) {
    footer {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
    }
  }
</style>
