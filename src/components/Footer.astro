---
import Icon from "./Icon.astro";
const currentYear = new Date().getFullYear();
---

<footer>
  <p>Designed and built in Bouskoura with <a href="https://astro.build/">Astro</a>.</p>
  <p>&copy; {currentYear} Mohamed Moughamir</p>
  <p class="links">
    <a href="https://github.com/moughamir">GitHub</a>
    <a href="https://linkedin.com/in/moughamir">LinkedIn</a>
    <a href="javascript:void(0)" data-email="bW91Z2hhbWlyQGdtYWlsLmNvbQ==" onclick="location.href='mailto:'+atob(this.dataset.email)">Email</a>
  </p>
</footer>

<style>
  footer {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    justify-content: space-between;
    padding: 2rem 1.25rem;
    color: var(--gray-500);
    font-size: 0.92rem;
  }

  a {
    color: var(--gray-0);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }

  @media (min-width: 50em) {
    footer {
      flex-direction: row;
      align-items: center;
      padding: 2.5rem 5rem;
    }
  }
</style>
