---
import Icon from "./Icon.astro";

const encodedEmail = btoa("moughamir@gmail.com");
---

<aside>
  <div>
    <p class="label">Available for useful work</p>
    <h2>Need a senior builder who can start fast?</h2>
    <p>
      Send the problem, current link or repo, and what success should look like.
      I can help with full-stack product work, rescue sprints, automation, and
      practical technical leadership.
    </p>
  </div>
  <a
    href="javascript:void(0)"
    data-email={encodedEmail}
    onclick="location.href='mailto:'+atob(this.dataset.email)"
    class="cta-btn"
  >
     Get In Touch
    <Icon icon="paper-plane-tilt" size="1.2em" />
  </a>
</aside>

<style>
  aside {
    display: grid;
    gap: 2rem;
    align-items: center;
    border-top: 1px solid var(--gray-800);
    border-bottom: 1px solid var(--gray-800);
    padding: clamp(3rem, 8vw, 7rem) 1.5rem;
    background-color: var(--gray-900);
  }

  div {
    max-width: 54rem;
  }

  .label {
    color: var(--gray-500);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h2 {
    max-width: 15ch;
    margin-top: 0.5rem;
    color: var(--gray-0);
    font-size: clamp(2rem, 5vw, 4rem);
    letter-spacing: -0.06em;
    line-height: 0.98;
  }

  p:last-child {
    max-width: 58ch;
    margin-top: 1rem;
    color: var(--gray-500);
    font-size: 1.05rem;
    line-height: 1.65;
  }

  .cta-btn {
    display: inline-flex;
    place-content: center;
    align-items: center;
    gap: 0.65em;
    min-height: 2.75rem;
    padding: 0.78rem 1rem;
    border-radius: 0.55rem;
    background: var(--gray-0);
    color: var(--gray-999);
    font-weight: 500;
    line-height: 1.1;
    text-align: center;
    text-decoration: none;
    box-shadow: var(--border-shadow);
    white-space: nowrap;
    transition: transform var(--theme-transition), box-shadow var(--theme-transition);
  }

  .cta-btn:focus,
  .cta-btn:hover {
    transform: translateY(-1px);
    box-shadow: var(--card-shadow-strong);
  }

  @media (min-width: 50em) {
    aside {
      grid-template-columns: 1fr auto;
      padding-inline: 5rem;
    }
  }
</style>
