---
import Icon from "./Icon.astro";
---

<aside class="brutal-card contact-cta">
  <div class="card-content">
    <p class="label">Available for useful work</p>
    <h2 class="cta-title">NEED A SENIOR BUILDER WHO CAN START FAST?</h2>
    <p class="cta-lede">
      I help with full-stack product work, rescue sprints, AI automation, and practical technical leadership.
    </p>
    <div class="cta-row">
      <a href="/hire/" class="brutal-btn">
        HIRE ME
      </a>
      <a href="https://linkedin.com/in/moughamir" class="ghost-link">LINKEDIN</a>
    </div>
  </div>
</aside>

<style>
  .contact-cta {
    background: var(--gray-0);
    color: var(--gray-999);
    margin-top: 5rem;
  }

  .cta-title {
    font-size: clamp(2rem, 6vw, 4.5rem);
    line-height: 1.1;
    font-weight: 900;
    margin-bottom: 1.5rem;
    color: var(--gray-999);
  }

  .cta-lede {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--gray-300);
    max-width: 50ch;
    margin-bottom: 3rem;
  }

  .cta-row {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .ghost-link {
    color: var(--gray-999);
    font-weight: 800;
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 0.3em;
  }

  .label {
    color: var(--accent-regular);
    font-family: var(--font-mono);
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 1rem;
    display: block;
  }
</style>

