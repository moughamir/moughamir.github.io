---
import Icon from "./Icon.astro";
import ThemeToggle from "./ThemeToggle.astro";
import type { iconPaths } from "./IconPaths";

const textLinks: { label: string; href: string }[] = [
  { label: "Work", href: "/work/" },
  { label: "Topics", href: "/topics/" },
  { label: "Hire", href: "/hire/" },
  { label: "About", href: "/about/" },
  { label: "Resume", href: "/resume/" },
  { label: "Blog", href: "/blog/" },
];

const iconLinks: {
  label: string;
  href: string;
  icon: keyof typeof iconPaths;
  encoded?: string;
}[] = [
  { label: "GitHub", href: "https://github.com/moughamir", icon: "github-logo" },
  { label: "LinkedIn", href: "https://linkedin.com/in/moughamir", icon: "linkedin-logo" },
  { label: "Email", href: "javascript:void(0)", icon: "mail", encoded: "bW91Z2hhbWlyQGdtYWlsLmNvbQ==" },
];

const isCurrentPage = (href: string) => {
  let pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, "");
  if (pathname.at(0) !== "/") pathname = "/" + pathname;
  if (pathname.at(-1) !== "/") pathname += "/";
  return pathname === href || (href !== "/" && pathname.startsWith(href));
};
---

<nav>
  <div class="nav-brand">
    <a href="/" class="site-title" aria-label="Mohamed Moughamir home">
      <Icon icon="terminal-window" size="1.25em" />
      <span>Mohamed Moughamir</span>
    </a>
  </div>

  <div class="nav-center">
    <div class="nav-links" aria-label="Main navigation">
      {textLinks.map(({ label, href }) => (
        <a aria-current={isCurrentPage(href) ? "page" : null} class="link" href={href}>{label}</a>
      ))}
    </div>

    <div class="nav-actions">
      {iconLinks.map(({ href, icon, label, encoded }) => {
        const extra = encoded ? { "data-email": encoded, onclick: "location.href='mailto:'+atob(this.dataset.email)" } : {};
        return <a href={href} class="social" aria-label={label} {...extra}><Icon icon={icon} size="1.1em" /></a>;
      })}
      <ThemeToggle />
      <a class="hire" href="/hire/">Hire me</a>
    </div>
  </div>
</nav>

<style>
  nav {
    z-index: 50;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 0;
    gap: 1.5rem;
    font-family: var(--font-brand);
    border-bottom: 2px solid var(--gray-0);
    margin-bottom: 4rem;
    background: var(--color-base-100);
    position: relative;
  }

  .site-title {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 900;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--gray-0);
    font-size: 1.25rem;
    letter-spacing: -0.02em;
    white-space: nowrap;
  }

  .nav-center {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-grow: 1;
    justify-content: center;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .link {
    text-decoration: none;
    color: var(--gray-100);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.85rem;
    transition: color 0.1s;
    white-space: nowrap;
  }

  .link:hover,
  .link[aria-current="page"] {
    color: var(--accent-regular);
  }

  .social {
    color: var(--gray-100);
    transition: transform 0.1s;
  }

  .social:hover {
    transform: translateY(-2px);
    color: var(--accent-regular);
  }

  .hire {
    display: inline-flex;
    padding: 0.5rem 1.25rem;
    background: var(--gray-0);
    color: var(--gray-999);
    font-weight: 900;
    text-transform: uppercase;
    text-decoration: none;
    font-size: 0.8rem;
    transition: transform 0.1s, box-shadow 0.1s;
    border: 2px solid var(--gray-0);
  }

  .hire:hover {
    transform: translate(-2px, -2px);
    box-shadow: 4px 4px 0 0 var(--accent-regular);
  }

  @media (max-width: 64em) {
    nav {
      flex-direction: column;
      text-align: center;
      padding: 1rem;
    }
    
    .nav-center {
      flex-direction: column;
      gap: 1rem;
      width: 100%;
    }

    .nav-links {
      justify-content: center;
      width: 100%;
    }
  }
</style>
