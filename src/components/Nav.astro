---
import Icon from "./Icon.astro";
import ThemeToggle from "./ThemeToggle.astro";

const textLinks: { label: string; href: string }[] = [
  { label: "Blog", href: "/blog/" },
  { label: "About", href: "/about/" },
];

const isCurrentPage = (href: string) => {
  let pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, "");
  if (pathname.at(0) !== "/") pathname = "/" + pathname;
  if (pathname.at(-1) !== "/") pathname += "/";
  return pathname === href || (href !== "/" && pathname.startsWith(href));
};
---

<div class="nav-container">
  <nav>
    <div class="nav-brand">
      <a href="/" class="site-title" aria-label="Mohamed Moughamir home">
        <Icon icon="terminal-window" size="1.1rem" />
      </a>
    </div>

    <div class="nav-links" aria-label="Main navigation">
      {textLinks.map(({ label, href }) => (
        <a aria-current={isCurrentPage(href) ? "page" : null} class="link" href={href}>{label}</a>
      ))}
    </div>

    <div class="nav-actions">
      <a href="https://moughamir.substack.com" class="social" aria-label="Substack" target="_blank" rel="noopener noreferrer"><Icon icon="substack" size="1rem" /></a>
      <ThemeToggle />
      <a class="hire" href="/hire/">Hire</a>
    </div>
  </nav>
</div>

<style>
  .nav-container {
    position: sticky;
    top: 1.5rem;
    z-index: 50;
    display: flex;
    justify-content: center;
    padding: 0 1rem;
    margin-bottom: 2rem;
  }

  nav {
    display: flex;
    align-items: center;
    padding: 0.5rem 1rem;
    gap: 1.5rem;
    background: color-mix(in srgb, var(--gray-999) 70%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--gray-800);
    border-radius: 999px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
  }

  .site-title {
    display: flex;
    align-items: center;
    color: var(--gray-0);
    text-decoration: none;
    transition: transform 0.2s ease;
  }

  .site-title:hover {
    transform: scale(1.1);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .link {
    font-size: 0.8rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--gray-200);
    transition: color 0.2s ease;
  }

  .link:hover,
  .link[aria-current="page"] {
    color: var(--accent-regular);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-left: 0.75rem;
    border-left: 1px solid var(--gray-800);
  }

  .social {
    color: var(--gray-300);
    transition: color 0.2s ease;
    display: flex;
  }

  .social:hover {
    color: var(--accent-regular);
  }

  .hire {
    font-size: 0.75rem;
    font-weight: 600;
    text-decoration: none;
    padding: 0.35rem 0.85rem;
    background: var(--accent-regular);
    color: white;
    border-radius: 999px;
    transition: filter 0.2s ease;
  }

  .hire:hover {
    filter: brightness(1.1);
  }

  @media (max-width: 30em) {
    nav {
      gap: 1rem;
      padding: 0.5rem 0.75rem;
    }
    
    .nav-actions {
      gap: 0.5rem;
    }
  }
</style>
