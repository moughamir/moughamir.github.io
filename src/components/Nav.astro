---
import Icon from "./Icon.astro";
import ThemeToggle from "./ThemeToggle.astro";
import type { iconPaths } from "./IconPaths";

const textLinks: { label: string; href: string }[] = [
  { label: "Work", href: "/work/" },
  { label: "About", href: "/about/" },
  { label: "Resume", href: "/resume/" },
  { label: "Blog", href: "/blog/" },
];

const iconLinks: {
  label: string;
  href: string;
  icon: keyof typeof iconPaths;
  encoded?: string;
}[] = [
  { label: "GitHub", href: "https://github.com/moughamir", icon: "github-logo" },
  { label: "LinkedIn", href: "https://linkedin.com/in/moughamir", icon: "linkedin-logo" },
  { label: "Email", href: "javascript:void(0)", icon: "mail", encoded: "bW91Z2hhbWlyQGdtYWlsLmNvbQ==" },
];

const isCurrentPage = (href: string) => {
  let pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, "");
  if (pathname.at(0) !== "/") pathname = "/" + pathname;
  if (pathname.at(-1) !== "/") pathname += "/";
  return pathname === href || (href !== "/" && pathname.startsWith(href));
};
---

<nav>
  <div class="nav-brand">
    <a href="/" class="site-title" aria-label="Mohamed Moughamir home">
      <Icon icon="terminal-window" size="1.25em" />
      <span>Mohamed Moughamir</span>
    </a>
  </div>

  <div class="nav-center">
    <div class="nav-links" aria-label="Main navigation">
      {textLinks.map(({ label, href }) => (
        <a aria-current={isCurrentPage(href) ? "page" : null} class="link" href={href}>{label}</a>
      ))}
    </div>

    <div class="nav-actions">
      {iconLinks.map(({ href, icon, label, encoded }) => {
        const extra = encoded ? { "data-email": encoded, onclick: "location.href='mailto:'+atob(this.dataset.email)" } : {};
        return <a href={href} class="social" aria-label={label} {...extra}><Icon icon={icon} size="1.1em" /></a>;
      })}
      <ThemeToggle />
      <a class="hire" href="javascript:void(0)" data-email="bW91Z2hhbWlyQGdtYWlsLmNvbQ==" onclick="location.href='mailto:'+atob(this.dataset.email)">Hire me</a>
    </div>
  </div>
</nav>

<style>
  nav {
    z-index: 20;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem;
    align-items: center;
    padding: 1rem 1rem 2.5rem;
    font-family: var(--font-brand);
    overflow-x: hidden;
  }

  .site-title,
  .link,
  .social,
  .hire {
    color: var(--gray-0);
    text-decoration: none;
  }

  .site-title {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--accent-regular);
  }

  .nav-brand {
    justify-self: start;
  }

  .nav-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .nav-links,
  .nav-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    max-width: 100%;
    overflow: hidden;
  }

  .nav-links {
    justify-content: center;
  }

  .nav-actions {
    justify-content: center;
  }

  .link,
  .social,
  .hire {
    display: inline-flex;
    min-height: 2.25rem;
    align-items: center;
    justify-content: center;
    border-radius: 0.45rem;
    padding: 0.45rem 0.65rem;
    font-size: 0.92rem;
    font-weight: 500;
  }

  .link {
    color: var(--gray-500);
  }

  .link:hover,
  .link[aria-current="page"] {
    color: var(--link-color);
    background: var(--gray-950);
    box-shadow: var(--border-shadow);
  }

  .social {
    padding-inline: 0.5rem;
    color: var(--gray-500);
  }

  .social:hover {
    color: var(--link-color);
  }

  .hire {
    background: var(--button-bg);
    color: var(--accent-text-over);
  }

  .hire:hover {
    background: color-mix(in srgb, var(--button-bg) 80%, black);
  }

  @media (min-width: 50em) {
    nav {
      padding: 1.25rem 2rem 3.5rem;
    }

    .nav-center {
      flex-direction: row;
      justify-content: center;
      align-items: center;
      gap: 1.5rem;
    }

    .nav-links {
      justify-content: center;
      border-radius: 999px;
      padding: 0.25rem;
      background: var(--gray-999);
      box-shadow: var(--border-shadow);
    }

    .nav-actions {
      justify-content: center;
    }
  }
</style>
