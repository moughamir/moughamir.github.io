---
import Icon from "./Icon.astro";
import ThemeToggle from "./ThemeToggle.astro";
import type { iconPaths } from "./IconPaths";

const textLinks: { label: string; href: string }[] = [
  { label: "Work", href: "/work/" },
  { label: "About", href: "/about/" },
  { label: "Blog", href: "/blog/" },
];

const iconLinks: {
  label: string;
  href: string;
  icon: keyof typeof iconPaths;
}[] = [
  { label: "GitHub", href: "https://github.com/moughamir", icon: "github-logo" },
  { label: "LinkedIn", href: "https://linkedin.com/in/moughamir", icon: "linkedin-logo" },
];

const isCurrentPage = (href: string) => {
  let pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, "");
  if (pathname.at(0) !== "/") pathname = "/" + pathname;
  if (pathname.at(-1) !== "/") pathname += "/";
  return pathname === href || (href !== "/" && pathname.startsWith(href));
};
---

<nav>
  <a href="/" class="site-title" aria-label="Mohamed Moughamir home">
    <Icon icon="terminal-window" size="1.25em" />
    <span>Mohamed Moughamir</span>
  </a>

  <div class="nav-links" aria-label="Main navigation">
    {textLinks.map(({ label, href }) => (
      <a aria-current={isCurrentPage(href) ? "page" : null} class="link" href={href}>{label}</a>
    ))}
  </div>

  <div class="nav-actions">
    {iconLinks.map(({ href, icon, label }) => (
      <a href={href} class="social" aria-label={label}><Icon icon={icon} /></a>
    ))}
    <ThemeToggle />
    <a class="hire" href="mailto:moughamir@gmail.com">Hire me</a>
  </div>
</nav>

<style>
  nav {
    z-index: 20;
    display: grid;
    gap: 1rem;
    align-items: center;
    padding: 1rem 1.25rem 3rem;
    font-family: var(--font-brand);
  }

  .site-title,
  .link,
  .social,
  .hire {
    color: var(--gray-0);
    text-decoration: none;
  }

  .site-title {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    letter-spacing: -0.03em;
  }

  .nav-links,
  .nav-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }

  .link,
  .social,
  .hire {
    display: inline-flex;
    min-height: 2.25rem;
    align-items: center;
    justify-content: center;
    border-radius: 0.45rem;
    padding: 0.45rem 0.65rem;
    font-size: 0.92rem;
    font-weight: 500;
  }

  .link {
    color: var(--gray-500);
  }

  .link:hover,
  .link[aria-current="page"] {
    color: var(--gray-0);
    background: var(--gray-950);
    box-shadow: var(--border-shadow);
  }

  .social {
    padding-inline: 0.5rem;
    color: var(--gray-500);
  }

  .social:hover {
    color: var(--gray-0);
  }

  .hire {
    background: var(--gray-0);
    color: var(--gray-999);
  }

  @media (min-width: 50em) {
    nav {
      grid-template-columns: 1fr auto 1fr;
      padding: 1.25rem 5rem 4.5rem;
    }

    .nav-links {
      justify-content: center;
      border-radius: 999px;
      padding: 0.25rem;
      background: var(--gray-999);
      box-shadow: var(--border-shadow);
    }

    .nav-actions {
      justify-content: flex-end;
    }
  }
</style>
