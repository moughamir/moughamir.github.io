---
import type { CollectionEntry } from "astro:content";
import Icon from "./Icon.astro";
import Pill from "./Pill.astro";

interface Props {
    article: CollectionEntry<"blog">;
    variant?: "default" | "wide" | "tall";
}

const { data, id } = Astro.props.article;
const variant = Astro.props.variant ?? "default";

const formattedDate = data.publishDate.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
});
---

<div class="brutal-card-wrapper">
    <div class="brutal-card">
        <div class="card-image" style={`background-image: url(${data.img || ''})`} />
        <div class="card-content">
            <div class="card-top">
                <time class="card-date" datetime={data.publishDate.toISOString()}>
                    {formattedDate}
                </time>
            </div>
            <a href={`/blog/${id}`} class="card-body-link">
                <div class="card-body">
                    <h2 class="card-title">{data.title}</h2>
                    <p class="card-description">{data.description}</p>
                </div>
            </a>
            <div class="card-footer">
                <ul class="card-tags">
                    {data.tags.slice(0, 3).map((t) => (
                        <li><a href={`/topics/${t.toLowerCase()}/`} class="tag-link"><Pill>{t}</Pill></a></li>
                    ))}
                </ul>
                <a href={`/blog/${id}`} class="card-arrow">
                    <Icon icon="arrow-right" size="1.2em" />
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .brutal-card-wrapper {
        position: relative;
    }

    .brutal-card {
        display: flex;
        flex-direction: column;
        min-height: 20rem;
        border: 2px solid var(--gray-0);
        background: var(--gray-999);
        position: relative;
        transition: transform 0.1s, box-shadow 0.1s;
    }

    .brutal-card:hover {
        transform: translate(-4px, -4px);
        box-shadow: 4px 4px 0 0 var(--accent-regular);
    }

    .card-image {
        position: absolute;
        inset: 0;
        z-index: 0;
        background-size: cover;
        background-position: center;
        opacity: 0.05;
        filter: grayscale(1);
        transition: opacity 0.2s;
    }

    .card-content {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        height: 100%;
        padding: 2rem;
    }

    .card-body-link {
        text-decoration: none;
        color: inherit;
        display: block;
        margin-top: 1rem;
    }

    .card-date {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--accent-regular);
        text-transform: uppercase;
    }

    .card-title {
        font-size: 1.5rem;
        font-weight: 800;
        text-transform: uppercase;
        line-height: 1.1;
        color: var(--gray-0);
        margin-bottom: 0.75rem;
    }

    .card-description {
        font-size: 0.95rem;
        line-height: 1.5;
        color: var(--gray-300);
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .card-footer {
        margin-top: auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 1.5rem;
    }

    .card-tags {
        display: flex;
        gap: 0.5rem;
        list-style: none;
        padding: 0;
        z-index: 2;
    }

    .tag-link {
        text-decoration: none;
        display: block;
    }

    .card-arrow {
        color: var(--gray-0);
        z-index: 2;
        transition: transform 0.1s;
    }

    .brutal-card:hover .card-arrow {
        transform: translateX(4px);
        color: var(--accent-regular);
    }
</style>
