---
import type { CollectionEntry } from 'astro:content';
import Icon from "./Icon.astro";
import Pill from "./Pill.astro";

interface Props {
	project: CollectionEntry<'work'>;
	variant?: 'default' | 'wide' | 'tall';
}

const { data, id } = Astro.props.project;
const variant = Astro.props.variant ?? 'default';

const formattedDate = data.publishDate.toLocaleDateString("en-US", {
	year: "numeric",
	month: "short",
	day: "numeric",
});
---

<div class="hover-3d">
	<a
		class:list={["bento-card", `bento-${variant}`]}
		href={`/work/${id}`}
	>
		<div class="bento-card-bloom" />
		<div class="bento-card-image" style={`background-image: url(${data.img || ''})`} />
		<div class="bento-card-content">
			<div class="bento-card-top">
				<time class="bento-date" datetime={data.publishDate.toISOString()}>
					{formattedDate}
				</time>
			</div>
			<div class="bento-card-body">
				<h2 class="bento-title">{data.title}</h2>
				<p class="bento-description">{data.description}</p>
			</div>
			<div class="bento-card-footer">
				<ul class="bento-tags">
					{data.tags.slice(0, 3).map((t) => (
						<li><Pill>{t}</Pill></li>
					))}
					{data.tags.length > 3 && (
						<li class="bento-tag-more">+{data.tags.length - 3}</li>
					)}
				</ul>
				<span class="bento-arrow">
					<Icon icon="arrow-right" size="0.85em" />
				</span>
			</div>
		</div>
	</a>
	<!-- 3D hover zones (invisible grid cells for tilt direction detection) -->
	<div></div><div></div><div></div>
	<div></div><div></div><div></div>
	<div></div><div></div>
</div>

<style>
	.bento-card {
		min-height: 18rem;
	}

	.bento-card-image {
		position: absolute;
		inset: 0;
		z-index: 0;
		background-size: cover;
		background-position: center;
		opacity: 0.10;
		transition: opacity 0.5s cubic-bezier(0.22, 1, 0.36, 1), transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
	}

	.bento-card:hover .bento-card-image {
		opacity: 0.18;
		transform: scale(1.04);
	}

	.bento-card-content {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		height: 100%;
		padding: 1.5rem;
		background: linear-gradient(
			180deg,
			transparent 0%,
			color-mix(in srgb, var(--gray-999) 70%, transparent) 35%,
			color-mix(in srgb, var(--gray-999) 90%, transparent) 65%,
			var(--gray-999) 100%
		);
		backdrop-filter: blur(2px);
		-webkit-backdrop-filter: blur(2px);
	}

	.bento-card-top {
		margin-bottom: auto;
	}

	.bento-date {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		color: var(--gray-500);
		font-family: var(--font-mono);
		font-size: 0.72rem;
		font-weight: 500;
		letter-spacing: 0.02em;
		padding: 0.3rem 0.7rem;
		background: color-mix(in srgb, var(--gray-999) 60%, transparent);
		border-radius: 999px;
		backdrop-filter: blur(16px) saturate(180%);
		-webkit-backdrop-filter: blur(16px) saturate(180%);
		border: 1px solid color-mix(in srgb, var(--gray-800) 30%, transparent);
		box-shadow:
			inset 0 1px 0 color-mix(in srgb, var(--gray-999) 60%, transparent),
			0 2px 6px rgba(0, 0, 0, 0.03);
	}

	.bento-card-body {
		padding-top: 1rem;
	}

	h2.bento-title {
		color: var(--gray-0);
		font-size: 1.2rem;
		font-weight: 600;
		letter-spacing: -0.03em;
		line-height: 1.25;
		margin-bottom: 0.5rem;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.bento-description {
		color: var(--gray-500);
		font-size: 0.88rem;
		line-height: 1.6;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.bento-card-footer {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 0.75rem;
		padding-top: 1rem;
		margin-top: auto;
	}

	.bento-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.bento-tag-more {
		display: inline-flex;
		align-items: center;
		padding: 0.2rem 0.55rem;
		border-radius: 999px;
		font-size: 0.7rem;
		font-weight: 500;
		color: var(--gray-500);
		background: color-mix(in srgb, var(--gray-900) 60%, transparent);
		border: 1px solid color-mix(in srgb, var(--gray-800) 30%, transparent);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
	}

	.bento-arrow {
		display: inline-flex;
		align-items: center;
		flex-shrink: 0;
		width: 2rem;
		height: 2rem;
		justify-content: center;
		border-radius: 999px;
		color: var(--gray-500);
		background: color-mix(in srgb, var(--gray-900) 50%, transparent);
		border: 1px solid color-mix(in srgb, var(--gray-800) 30%, transparent);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		box-shadow:
			inset 0 1px 0 color-mix(in srgb, var(--gray-999) 40%, transparent),
			0 2px 4px rgba(0, 0, 0, 0.03);
		transition:
			transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
			color 0.25s ease,
			background 0.25s ease,
			border-color 0.25s ease,
			box-shadow 0.25s ease;
	}

	.bento-card:hover .bento-arrow {
		transform: translateX(4px);
		color: var(--gray-0);
		background: color-mix(in srgb, var(--gray-800) 40%, transparent);
		border-color: color-mix(in srgb, var(--gray-600) 30%, transparent);
		box-shadow:
			inset 0 1px 0 color-mix(in srgb, var(--gray-999) 50%, transparent),
			0 4px 8px rgba(0, 0, 0, 0.06);
	}

	.bento-wide {
		grid-column: 1 / -1;
		min-height: 20rem;
	}

	.bento-wide h2.bento-title {
		font-size: 1.4rem;
	}

	.bento-tall {
		grid-row: span 2;
		min-height: 24rem;
	}

	.bento-tall .bento-card-image {
		opacity: 0.15;
	}

	.bento-tall h2.bento-title {
		font-size: 1.35rem;
	}

	@media (min-width: 50em) {
		.bento-card-content {
			padding: 2rem;
		}

		.bento-card {
			min-height: 20rem;
			border-radius: 42px;
		}

		.bento-wide {
			min-height: 22rem;
		}

		.bento-tall {
			min-height: 30rem;
		}

		.bento-wide h2.bento-title {
			font-size: 1.6rem;
		}

		.bento-tall h2.bento-title {
			font-size: 1.5rem;
		}

		.bento-description {
			-webkit-line-clamp: 3;
		}
	}
</style>
