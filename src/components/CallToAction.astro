---
interface Props {
	href?: string;
	email?: string;
}

const { href, email } = Astro.props;
const encoded = email ? btoa(email) : null;
---

{
	email ? (
		<a href="javascript:void(0)" data-email={encoded} onclick="location.href='mailto:'+atob(this.dataset.email)"><slot /></a>
	) : (
		<a href={href}><slot /></a>
	)
}

<style>
	a {
		display: inline-flex;
		place-content: center;
		align-items: center;
		gap: 0.65em;
		min-height: 2.75rem;
		padding: 0.78rem 1rem;
		border-radius: 0.55rem;
		background: var(--gray-0);
		color: var(--gray-999);
		font-weight: 500;
		line-height: 1.1;
		text-align: center;
		text-decoration: none;
		box-shadow: var(--border-shadow);
		white-space: nowrap;
		transition: transform var(--theme-transition), box-shadow var(--theme-transition);
	}

	a:focus,
	a:hover {
		transform: translateY(-1px);
		box-shadow: var(--card-shadow-strong);
	}
</style>
