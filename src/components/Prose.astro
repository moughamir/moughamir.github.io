<div class="prose-wrapper">
    <slot />
</div>

<style>
    .prose-wrapper {
        max-width: 65ch;
        padding: 0 1.25rem 4rem;
        margin: 0 auto;
    }

    .prose-wrapper :global(h1) {
        font-size: 1.75rem;
        font-weight: 700;
        line-height: 1.2;
        letter-spacing: -0.02em;
        margin-top: 3rem;
        margin-bottom: 1rem;
    }

    .prose-wrapper :global(h2) {
        font-size: 1.5rem;
        font-weight: 600;
        line-height: 1.25;
        letter-spacing: -0.02em;
        margin-top: 2.5rem;
        margin-bottom: 0.875rem;
    }

    .prose-wrapper :global(h3) {
        font-size: 1.25rem;
        font-weight: 600;
        line-height: 1.3;
        margin-top: 2rem;
        margin-bottom: 0.75rem;
    }

    .prose-wrapper :global(p) {
        font-size: 1rem;
        line-height: 1.7;
        color: var(--gray-300);
        margin-bottom: 1.25rem;
    }

    .prose-wrapper :global(a) {
        color: var(--link-color);
        text-decoration: underline;
        text-underline-offset: 0.2em;
    }

    .prose-wrapper :global(a:hover) {
        color: var(--accent-dark);
    }

    .prose-wrapper :global(ul),
    .prose-wrapper :global(ol) {
        padding-left: 1.5rem;
        margin-bottom: 1.25rem;
        color: var(--gray-300);
    }

    .prose-wrapper :global(li) {
        line-height: 1.7;
        margin-bottom: 0.5rem;
    }

    .prose-wrapper :global(code) {
        font-family: var(--font-mono);
        font-size: 0.875em;
        background: var(--gray-850);
        color: var(--gray-0);
        padding: 0.15em 0.4em;
        border-radius: 0;
    }

    .prose-wrapper :global(pre) {
        background: var(--gray-850);
        border-radius: 0;
        padding: 1.25rem;
        overflow-x: auto;
        margin-bottom: 1.5rem;
    }

    .prose-wrapper :global(pre) :global(code) {
        background: none;
        padding: 0;
        font-size: 0.875rem;
        line-height: 1.65;
    }



    .prose-wrapper :global(img) {
        max-width: 100%;
        height: auto;
        border-radius: 0;
        margin: 2rem 0;
    }

    .prose-wrapper :global(blockquote) {
        border-left: 2px solid var(--gray-300);
        padding-left: 1.25rem;
        margin: 1.5rem 0;
        color: var(--gray-500);
        font-style: italic;
    }

    .prose-wrapper :global(hr) {
        border: none;
        border-top: 1px solid var(--gray-800);
        margin: 2.5rem 0;
    }

    @media (min-width: 50em) {
        .prose-wrapper {
            padding: 0 2rem 6rem;
        }
    }
</style>