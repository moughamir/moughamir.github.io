---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactCTA from "../components/ContactCTA.astro";

const stack = [
  "React", "TypeScript", "Node.js", "PHP", "Python", "Astro", "Bun", "SQLite", "MongoDB", "MySQL", "WordPress", "Tailwind", "Git", "Linux"
];

const experienceSignals = [
  "10+ years across web development, startup experiments, freelance delivery, and business-facing product work.",
  "Public GitHub footprint across JavaScript, TypeScript, PHP, CSS, Python, Shell, Rust, Astro, and more.",
  "Comfortable moving between frontend polish, backend logic, deployment constraints, and stakeholder communication.",
  "Based in Bouskoura / Casablanca, available for Morocco, France/EMEA remote, contract, and full-time roles.",
];

const education = [
  {
    school: "Université Hassan II — FSJES Casablanca",
    detail: "Licence en Gestion d’Entreprise, 2011–2015",
  },
  {
    school: "HarvardX",
    detail: "CS50: Introduction to Computer Science, online coursework, 2016–2017",
  },
  {
    school: "MITx",
    detail: "Algorithms, Python programming, and introductory AI coursework, 2017",
  },
];
---

<BaseLayout
  title="About Mohamed Moughamir — Full-Stack Developer"
  description="Senior Software Engineer based in Morocco, expert in React, TypeScript, Bun, and agentic AI workflows. 10+ years experience building high-conversion, scalable web products."
>
  <main id="main-content" class="about wrapper">
    <section class="intro">
      <div class="profile-photo" aria-label="Mohamed Moughamir profile photo" role="img">
        <img
          src="/assets/portrait.png"
          alt="Mohamed Moughamir — Senior Software Engineer"
          width="96"
          height="96"
          loading="lazy"
        />
      </div>
      <p class="label">About</p>
      <h1>Senior Software Engineer: Product-Minded & Founder-Driven.</h1>
      <p>
        I'm Mohamed Moughamir, a Senior Software Engineer in Bouskoura, Morocco, specializing in high-performance web applications and agentic workflows. With over 10 years of experience, I blend product intuition with engineering precision to ship resilient, user-focused digital tools.
      </p>
      <p>
        My expertise spans React, TypeScript, Bun, and AI-assisted engineering (MCP/RAG). From refactoring complex enterprise monoliths to launching startup MVPs, I turn digital friction into seamless, high-converting product experiences. Currently open to remote Senior/Lead engineering roles in the EMEA region.
      </p>
    </section>

    <section class="social-links" aria-label="Connect with me">
      <a href="https://github.com/moughamir" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="social-btn">
        <svg width="18" height="18" viewBox="0 0 256 256" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"><g stroke-linecap="round" stroke-linejoin="round"><path fill="none" stroke-width="14.7" d="M55.7 167.2c13.9 1 21.3 13.1 22.2 14.6 4.2 7.2 10.4 9.6 18.3 7.1l1.1-3.4a60.3 60.3 0 0 1-25.8-11.9c-12-10.1-18-25.6-18-46.3"/><path fill="none" stroke-width="16" d="M61.4 205.1a24.5 24.5 0 0 1-3-6.1c-3.2-7.9-7.1-10.6-7.8-11.1l-1-.6c-2.4-1.6-9.5-6.5-7.2-13.9 1.4-4.5 6-7.2 12.3-7.2h.8c4 .3 7.6 1.5 10.7 3.2-9.1-10.1-13.6-24.3-13.6-42.3 0-11.3 3.5-21.7 10.1-30.4A46.7 46.7 0 0 1 65 67.3a8.3 8.3 0 0 1 5-4.7c2.8-.9 13.3-2.7 33.2 9.9a105 105 0 0 1 50.5 0c19.9-12.6 30.4-10.8 33.2-9.9 2.3.7 4.1 2.4 5 4.7 5 12.7 4 23.2 2.6 29.4 6.7 8.7 10 18.9 10 30.4 0 42.6-25.8 54.7-43.6 58.7 1.4 4.1 2.2 8.8 2.2 13.7l-.1 23.4v2.3"/><path fill="none" stroke-width="16" d="M160.9 185.7c1.4 4.1 2.2 8.8 2.2 13.7l-.1 23.4v2.3A98.6 98.6 0 1 0 61.4 205c-1.4-2.1-11.3-17.5-11.8-17.8-2.4-1.6-9.5-6.5-7.2-13.9 1.4-4.5 6-7.2 12.3-7.2h.8c4 .3 7.6 1.5 10.7 3.2-9.1-10.1-13.6-24.3-13.6-42.3 0-11.3 3.5-21.7 10.1-30.4A46.4 46.4 0 0 1 65 67.3a8.3 8.3 0 0 1 5-4.7c2.8-.9 13.3-2.7 33.2 9.9a105 105 0 0 1 50.5 0c19.9-12.6 30.4-10.8 33.2-9.9 2.3.7 4.1 2.4 5 4.7 5 12.7 4 23.2 2.6 29.4 6.7 8.7 10 18.9 10 30.4.1 42.6-25.8 54.7-43.6 58.6z"/><path fill="none" stroke-width="18.7" d="m170.1 203.3 17.3-12 17.2-18.7 9.5-26.6v-27.9l-9.5-27.5" /><path fill="none" stroke-width="22.7" d="m92.1 57.3 23.3-4.6 18.7-1.4 29.3 5.4m-110 32.6-8 16-4 21.4.6 20.3 3.4 13" /><path fill="none" stroke-width="13.3" d="M28.8 133a100 100 0 0 0 66.9 94.4v-8.7c-22.4 1.8-33-11.5-35.6-19.8-3.4-8.6-7.8-11.4-8.5-11.8"/></g></svg>
        <span>GitHub</span>
      </a>
      <a href="https://linkedin.com/in/moughamir" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="social-btn linkedin">
        <svg width="18" height="18" viewBox="0 0 256 256" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"><rect width="184" height="184" x="36" y="36" fill="none" stroke-width="16" rx="8"/><path d="M120 112v64m-32-64v64m32-36a28 28 0 0 1 56 0v36"/><circle cx="88" cy="80" r="12" stroke="none"/></svg>
        <span>LinkedIn</span>
        <span class="verified-tag">Verified</span>
      </a>
      <a href="https://youtube.com/@moughamir" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="social-btn">
        <svg width="18" height="18" viewBox="0 0 256 256" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"><path d="m160 128-48-32v64l48-32z"/><path d="M24 128c0 30 3 47 5 56a16 16 0 0 0 10 11c34 13 89 13 89 13s56 0 89-13a16 16 0 0 0 10-11c2-9 5-26 5-56s-3-47-5-56a16 16 0 0 0-10-11c-33-13-89-13-89-13s-55 0-89 13a16 16 0 0 0-10 11c-2 9-5 26-5 56Z"/></svg>
        <span>YouTube</span>
      </a>
      <a href="/feed.xml" aria-label="Podcast RSS" class="social-btn">
        <svg width="18" height="18" viewBox="0 0 256 256" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
        <span>Podcast</span>
      </a>
      <a href="mailto:moughamir@gmail.com" aria-label="Email" class="social-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        <span>Email</span>
      </a>
    </section>

    <section class="two-column">
      <div>
        <p class="label">How I help</p>
        <h2>I turn unclear digital problems into shipped next steps.</h2>
      </div>
      <div class="copy-stack">
        <p>
          I can design and build a landing page, repair a broken website, modernize a PHP/WordPress stack, ship React/TypeScript product features, wire APIs, automate a workflow, or help a small team make technical decisions without overcomplicating the system.
        </p>
        <p>
          I’m not only interested in code that compiles. I care about whether the page converts, whether the handoff is understandable, whether the system can be maintained, and whether the work creates business value quickly.
        </p>
      </div>
    </section>

    <section class="signal-grid" aria-label="Experience signals">
      {experienceSignals.map((signal) => <article>{signal}</article>)}
    </section>

    <section class="two-column">
      <div>
        <p class="label">Stack</p>
        <h2>Broad web range, with a practical full-stack core.</h2>
      </div>
      <ul class="tag-cloud">
        {stack.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="two-column">
      <div>
        <p class="label">Work style</p>
        <h2>Calm, direct, useful.</h2>
      </div>
      <div class="copy-stack">
        <p>
          I like small, sharp execution loops: understand the constraint, identify the highest-leverage fix, ship something visible, then iterate with evidence.
        </p>
        <p>
          That makes me useful for startups, agencies, founders, and teams that need someone who can cross boundaries: design, frontend, backend, content, automation, and product judgment.
        </p>
      </div>
    </section>

    <section class="two-column">
      <div>
        <p class="label">Education</p>
        <h2>Business foundation, computer science self-study, continuous practice.</h2>
      </div>
      <div class="timeline">
        {education.map((item) => (
          <article>
            <h3>{item.school}</h3>
            <p>{item.detail}</p>
          </article>
        ))}
      </div>
    </section>
  </main>

  <ContactCTA />
</BaseLayout>

<style>
  .about {
    display: flex;
    flex-direction: column;
    gap: 5rem;
    padding-bottom: 5rem;
  }

  .label {
    color: var(--gray-500);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .intro {
    max-width: 68rem;
  }

  .profile-photo img,
  .profile-photo .initials {
    width: 96px;
    height: 96px;
    border-radius: 9999px;
    object-fit: cover;
  }

  .profile-photo {
    width: 96px;
    height: 96px;
    border-radius: 9999px;
    background-color: var(--gray-900);
    border: 1px solid var(--gray-800);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    overflow: hidden;
  }

  .initials {
    color: var(--gray-500);
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  h1,
  h2 {
    color: var(--gray-0);
    letter-spacing: -0.065em;
  }

  h1 {
    max-width: 13ch;
    margin-top: 0.5rem;
    font-size: clamp(3rem, 9vw, 6rem);
    line-height: 0.92;
  }

  h2 {
    max-width: 13ch;
    margin-top: 0.4rem;
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 0.98;
  }

  .intro p:not(.label),
  .copy-stack p {
    max-width: 64ch;
    margin-top: 1.25rem;
    color: var(--gray-500);
    font-size: 1.1rem;
    line-height: 1.7;
  }

  .two-column {
    display: grid;
    gap: 1.5rem;
  }

  .copy-stack p:first-child {
    margin-top: 0;
  }

  .signal-grid {
    display: grid;
    gap: 1rem;
  }

  .signal-grid article,
  .timeline article {
    border-radius: 1rem;
    padding: 1.25rem;
    color: var(--gray-0);
    background: var(--gray-999);
    box-shadow: var(--card-shadow);
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    padding: 0;
    list-style: none;
  }

  .tag-cloud li {
    border-radius: 999px;
    padding: 0.5rem 0.75rem;
    color: var(--gray-0);
    background: var(--gray-950);
    font-family: var(--font-mono);
    font-size: 0.86rem;
    box-shadow: var(--border-shadow);
  }

  .timeline {
    display: grid;
    gap: 1rem;
  }

  .timeline h3 {
    color: var(--gray-0);
    font-size: 1.2rem;
    letter-spacing: -0.03em;
  }

  .timeline p {
    margin-top: 0.4rem;
    color: var(--gray-500);
  }

  .social-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.5rem;
  }

  .social-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    color: var(--gray-500);
    background: var(--gray-950);
    border: 1px solid var(--gray-800);
    font-size: 0.82rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 160ms ease, border-color 160ms ease;
  }

  .social-btn:hover {
    color: var(--gray-0);
    border-color: var(--gray-600);
  }

  .social-btn.linkedin {
    border-color: var(--gray-700);
  }

  .verified-tag {
    display: inline-flex;
    align-items: center;
    padding: 0.1rem 0.4rem;
    margin-left: 0.2rem;
    border-radius: 999px;
    background: var(--accent-light);
    color: var(--gray-999);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  @media (min-width: 52rem) {
    .two-column {
      grid-template-columns: 0.85fr 1fr;
      align-items: start;
    }

    .signal-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
</style>
