---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactCTA from "../components/ContactCTA.astro";

const stack = [
  "React", "TypeScript", "Node.js", "PHP", "Python", "Astro", "Bun", "SQLite", "MongoDB", "MySQL", "WordPress", "Tailwind", "Git", "Linux"
];

const experienceSignals = [
  "10+ years across web development, startup experiments, freelance delivery, and business-facing product work.",
  "Public GitHub footprint across JavaScript, TypeScript, PHP, CSS, Python, Shell, Rust, Astro, and more.",
  "Comfortable moving between frontend polish, backend logic, deployment constraints, and stakeholder communication.",
  "Based in Bouskoura / Casablanca, available for Morocco, France/EMEA remote, contract, and full-time roles.",
];

const education = [
  {
    school: "Université Hassan II — FSJES Casablanca",
    detail: "Licence en Gestion d’Entreprise, 2011–2015",
  },
  {
    school: "HarvardX",
    detail: "CS50: Introduction to Computer Science, online coursework, 2016–2017",
  },
  {
    school: "MITx",
    detail: "Algorithms, Python programming, and introductory AI coursework, 2017",
  },
];
---

<BaseLayout
  title="About Mohamed Moughamir — Full-Stack Developer"
  description="About Mohamed Moughamir, a Morocco-based senior full-stack developer building practical web products with React, TypeScript, Node.js, PHP, Python, and AI-assisted workflows."
>
  <main class="about wrapper">
    <section class="intro">
      <p class="label">About</p>
      <h1>Product-minded full-stack developer with founder energy.</h1>
      <p>
        I’m Mohamed Moughamir, a full-stack developer based in Bouskoura / Casablanca, Morocco. My best work happens where product sense, clean interfaces, pragmatic engineering, and business urgency meet.
      </p>
      <p>
        I have spent more than a decade building, experimenting, freelancing, learning in public, and working across the messy middle between idea and shipped software. I’m currently available for full-time roles, contract work, and focused web rescue sprints.
      </p>
    </section>

    <section class="two-column">
      <div>
        <p class="label">How I help</p>
        <h2>I turn unclear digital problems into shipped next steps.</h2>
      </div>
      <div class="copy-stack">
        <p>
          I can design and build a landing page, repair a broken website, modernize a PHP/WordPress stack, ship React/TypeScript product features, wire APIs, automate a workflow, or help a small team make technical decisions without overcomplicating the system.
        </p>
        <p>
          I’m not only interested in code that compiles. I care about whether the page converts, whether the handoff is understandable, whether the system can be maintained, and whether the work creates business value quickly.
        </p>
      </div>
    </section>

    <section class="signal-grid" aria-label="Experience signals">
      {experienceSignals.map((signal) => <article>{signal}</article>)}
    </section>

    <section class="two-column">
      <div>
        <p class="label">Stack</p>
        <h2>Broad web range, with a practical full-stack core.</h2>
      </div>
      <ul class="tag-cloud">
        {stack.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="two-column">
      <div>
        <p class="label">Work style</p>
        <h2>Calm, direct, useful.</h2>
      </div>
      <div class="copy-stack">
        <p>
          I like small, sharp execution loops: understand the constraint, identify the highest-leverage fix, ship something visible, then iterate with evidence.
        </p>
        <p>
          That makes me useful for startups, agencies, founders, and teams that need someone who can cross boundaries: design, frontend, backend, content, automation, and product judgment.
        </p>
      </div>
    </section>

    <section class="two-column">
      <div>
        <p class="label">Education</p>
        <h2>Business foundation, computer science self-study, continuous practice.</h2>
      </div>
      <div class="timeline">
        {education.map((item) => (
          <article>
            <h3>{item.school}</h3>
            <p>{item.detail}</p>
          </article>
        ))}
      </div>
    </section>
  </main>

  <ContactCTA />
</BaseLayout>

<style>
  .about {
    display: flex;
    flex-direction: column;
    gap: 5rem;
    padding-bottom: 5rem;
  }

  .label {
    color: var(--gray-500);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .intro {
    max-width: 68rem;
  }

  h1,
  h2 {
    color: var(--gray-0);
    letter-spacing: -0.065em;
  }

  h1 {
    max-width: 13ch;
    margin-top: 0.5rem;
    font-size: clamp(3rem, 9vw, 6rem);
    line-height: 0.92;
  }

  h2 {
    max-width: 13ch;
    margin-top: 0.4rem;
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 0.98;
  }

  .intro p:not(.label),
  .copy-stack p {
    max-width: 64ch;
    margin-top: 1.25rem;
    color: var(--gray-500);
    font-size: 1.1rem;
    line-height: 1.7;
  }

  .two-column {
    display: grid;
    gap: 1.5rem;
  }

  .copy-stack p:first-child {
    margin-top: 0;
  }

  .signal-grid {
    display: grid;
    gap: 1rem;
  }

  .signal-grid article,
  .timeline article {
    border-radius: 1rem;
    padding: 1.25rem;
    color: var(--gray-0);
    background: var(--gray-999);
    box-shadow: var(--card-shadow);
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    padding: 0;
    list-style: none;
  }

  .tag-cloud li {
    border-radius: 999px;
    padding: 0.5rem 0.75rem;
    color: var(--gray-0);
    background: var(--gray-950);
    font-family: var(--font-mono);
    font-size: 0.86rem;
    box-shadow: var(--border-shadow);
  }

  .timeline {
    display: grid;
    gap: 1rem;
  }

  .timeline h3 {
    color: var(--gray-0);
    font-size: 1.2rem;
    letter-spacing: -0.03em;
  }

  .timeline p {
    margin-top: 0.4rem;
    color: var(--gray-500);
  }

  @media (min-width: 52rem) {
    .two-column {
      grid-template-columns: 0.85fr 1fr;
      align-items: start;
    }

    .signal-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
</style>
