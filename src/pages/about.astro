---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactCTA from "../components/ContactCTA.astro";

const stack = [
  "React", "Redux", "Saga", "Flux", "JSS", "Storybook", "HTML5/CSS3", "Sass", "Next.js", "Tailwind CSS",
  "Node.js", "PHP (Symfony)", "Python", "Bun",
  "PostgreSQL", "MySQL", "MongoDB", "SQLite3", "Redis", "Supabase",
  "Docker", "Podman", "Kubernetes", "Buildah", "AWS", "GCP", "Azure", "CI/CD", "Nginx", "Linux",
  "Groq API", "Google Gemini", "Vercel AI SDK", "Git", "TDD", "Agile/Scrum", "Git Flow", "PARA/Zettelkasten"
];

const experienceSignals = [
  "10+ years across web development, startup experiments, freelance delivery, and business-facing product work.",
  "Currently Tech Lead at ANAQIO, engineering an AI-driven fashion commerce platform with Bun, Next.js, TypeScript, and Supabase.",
  "Building high-performance web applications since 2015 — from React frontends to Node.js microservices, from CMS platforms to AI inference pipelines.",
  "Based in Casablanca, Morocco. Available for Morocco, France/EMEA remote, contract, and full-time roles."
];

const education = [
  {
    school: "Université Hassan II — FSJES Casablanca",
    detail: "Licence en Gestion d'Entreprise, 2011–2015",
  },
  {
    school: "HarvardX",
    detail: "CS50: Introduction to Computer Science, online coursework, 2016–2017",
  },
  {
    school: "MITx",
    detail: "Algorithms, Python programming, and introductory AI coursework, 2017",
  },
];
---

<BaseLayout
  title="About Mohamed Moughamir — Full-Stack Developer"
  description="Senior Software Engineer based in Morocco, expert in React, TypeScript, Bun, and agentic AI workflows."
>
  <main id="main-content" class="about wrapper stack gap-20">
    <section class="intro-section">
      <div class="brutal-card intro-card">
        <div class="card-content">
          <p class="label">About</p>
          <h1 class="title">Senior Software Engineer: Product-Minded & Founder-Driven.</h1>
          <p class="lede">
            I'm Mohamed Moughamir, a Senior Full-Stack Engineer based in Casablanca, Morocco. With over 10 years of experience, I blend product intuition with engineering precision to ship resilient, user-focused digital tools.
          </p>
          <p class="lede">
            My expertise spans React, TypeScript, Bun, Node.js, and AI-assisted engineering. Currently open to remote Senior/Lead engineering roles in the EMEA region.
          </p>
        </div>
      </div>
      
      <div class="brutal-card portrait-card">
        <div class="card-content centered">
          <div class="profile-photo">
            <img
              src="/assets/portrait.png"
              alt="Mohamed Moughamir — Senior Software Engineer"
              width="120"
              height="140"
              loading="lazy"
            />
          </div>
          <p class="label">Status</p>
          <div class="status-badge">
            <span class="dot"></span>
            Available Now
          </div>
        </div>
      </div>
    </section>

    <section class="signals-section stack gap-8">
      <h2 class="section-title">Signals</h2>
      <div class="signals-grid">
        {experienceSignals.map((signal) => (
          <article class="brutal-card signal-card">
            <div class="card-content">
              <p>{signal}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="capabilities-section grid-2-col">
      <div class="brutal-card">
        <div class="card-content">
          <p class="label">How I help</p>
          <h3>I turn unclear digital problems into shipped next steps.</h3>
          <div class="copy-stack">
            <p>
              I can design and build a landing page, repair a broken website, modernize a PHP/WordPress stack, ship React/TypeScript product features, or automate a workflow without overcomplicating the system.
            </p>
          </div>
        </div>
      </div>

      <div class="brutal-card">
        <div class="card-content">
          <p class="label">Work style</p>
          <h3>Calm, direct, useful.</h3>
          <div class="copy-stack">
            <p>
              I like small, sharp execution loops: understand the constraint, identify the highest-leverage fix, ship something visible, then iterate with evidence.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="stack-section">
      <div class="brutal-card">
        <div class="card-content">
          <p class="label">The Stack</p>
          <h2 class="section-title">Broad web range, practical full-stack core.</h2>
          <ul class="tag-cloud">
            {stack.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </div>
    </section>

    <section class="edu-section stack gap-8">
      <h2 class="section-title">Education</h2>
      <div class="edu-grid">
        {education.map((item) => (
          <article class="brutal-card">
            <div class="card-content">
              <h3>{item.school}</h3>
              <p>{item.detail}</p>
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>
  <ContactCTA />
</BaseLayout>

<style>
  .about {
    padding: 6rem 0;
  }

  .intro-section {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
  }

  .label {
    color: var(--accent-regular);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 1rem;
    display: block;
  }

  .title {
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    line-height: 0.95;
    margin-bottom: 2rem;
  }

  .lede {
    font-size: 1.2rem;
    color: var(--gray-300);
    max-width: 60ch;
    margin-bottom: 1.5rem;
    font-weight: 500;
    line-height: 1.5;
  }

  .profile-photo {
    width: 120px;
    height: 140px;
    background: var(--gray-100);
    border: 2px solid var(--gray-0);
    margin-bottom: 1.5rem;
    overflow: hidden;
  }

  .profile-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1);
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 800;
    text-transform: uppercase;
    font-size: 0.9rem;
    color: var(--gray-0);
  }

  .dot {
    width: 10px;
    height: 10px;
    background: #16a34a;
    border-radius: 0;
    border: 1px solid var(--gray-0);
  }

  .section-title {
    font-size: 2.5rem;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    margin-bottom: 2rem;
  }

  .signals-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  }

  .signal-card {
    font-weight: 600;
    color: var(--gray-100);
    line-height: 1.5;
  }

  .grid-2-col {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
  }

  .copy-stack p {
    color: var(--gray-300);
    font-weight: 500;
    line-height: 1.6;
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    list-style: none;
    padding: 0;
    margin-top: 2rem;
  }

  .tag-cloud li {
    padding: 0.4rem 0.8rem;
    border: 1px solid var(--gray-0);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    background: var(--gray-999);
  }

  .edu-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  }

  .edu-grid h3 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .edu-grid p {
    color: var(--gray-300);
    font-weight: 500;
  }

  .centered {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  @media (min-width: 60rem) {
    .intro-section {
      grid-template-columns: 1fr 300px;
    }
    .grid-2-col {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
