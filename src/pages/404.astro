---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not Found" description="404 Error — this page was not found">
  <main id="main-content" class="not-found wrapper stack gap-8">
    <div class="brutal-card error-card">
      <div class="card-content centered">
        <div class="code">404</div>
        <h1 class="title">Page not found</h1>
        <p class="lede">
          The page you're looking for doesn't exist or has been moved.
        </p>
        <div class="links">
          <a href="/" class="brutal-btn">Back to home</a>
          <a href="/about/" class="ghost-link">About me</a>
          <a href="/work/" class="ghost-link">Work</a>
          <a href="/blog/" class="ghost-link">Blog</a>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .not-found {
    padding: 10rem 0;
    align-items: center;
    justify-content: center;
  }

  .error-card {
    max-width: 40rem;
    width: 100%;
  }

  .code {
    font-size: clamp(5rem, 15vw, 10rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.05em;
    color: var(--accent-regular);
    margin-bottom: 1.5rem;
  }

  .title {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .lede {
    font-size: 1.25rem;
    color: var(--gray-300);
    margin-bottom: 3rem;
    max-width: 30ch;
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    justify-content: center;
    align-items: center;
  }

  .ghost-link {
    font-weight: 800;
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 0.3em;
    color: var(--gray-0);
  }

  .centered {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
</style>
