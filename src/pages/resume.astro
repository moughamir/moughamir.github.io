---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactCTA from "../components/ContactCTA.astro";
import Icon from "../components/Icon.astro";
import SkillTag from "../components/SkillTag.astro";

const profile = {
  name: "Mohamed Moughamir",
  title: "Senior Full-Stack Engineer",
  phone: "(+212) 629-144-679",
  email: "moughamir@gmail.com",
  github: "https://github.com/moughamir",
  linkedin: "https://linkedin.com/in/moughamir",
  website: "https://moughamir.github.io",
  location: "Casablanca, Morocco",
};

const experience = [
  {
    role: "Tech Lead",
    company: "ANAQIO",
    location: "Casablanca",
    dates: "2026 – Present",
    highlights: [
      "Orchestrating core technology strategy for AI-driven fashion commerce studio",
      "Engineering with Bun, Next.js, TypeScript, Supabase",
      "Integrating AI via Vercel AI SDK, Groq, Google Gemini APIs",
    ],
  },
  {
    role: "Senior Full-Stack Engineer",
    company: "HiBR Digital / Spotbills",
    location: "Marina",
    dates: "Dec 2020 – Present",
    highlights: [
      "Architected high-performance web applications with React, Next.js, TypeScript",
      "Optimized CI/CD pipelines and cloud infrastructure on GCP/AWS",
    ],
  },
  {
    role: "Full-Stack Trainer",
    company: "YouCode (Simplon)",
    location: "Youssoufia",
    dates: "2021",
    highlights: [
      "Spearheaded FEBE engineering tracks and supervised curriculum engineering",
    ],
  },
];

const skills = {
  frontend: ["React", "Redux", "Saga", "Next.js", "Tailwind CSS"],
  backend: ["Node.js", "PHP (Symfony)", "Python", "Bun"],
  ai: ["LLM deployment", "Vercel AI SDK", "MCP", "RAG"],
  devops: ["Docker", "Kubernetes", "AWS", "CI/CD", "Linux"],
};

const skillIcons: Record<string, string | undefined> = {
  React: "react",
  Redux: "redux",
  "Next.js": "nextdotjs",
  "Tailwind CSS": "tailwind-css",
  "Node.js": "nodedotjs",
  "PHP (Symfony)": "php",
  Python: "python",
  Bun: "bun",
  Docker: "docker",
  AWS: "aws",
  Linux: "linux",
};

const education = [
  {
    school: "Université Hassan II — FSJES Casablanca",
    detail: "Licence en Gestion d'Entreprise",
    dates: "2011–2015",
  },
  { school: "HarvardX CS50", detail: "Computer Science", dates: "2016" },
];
---

<BaseLayout
  title="Resume — Mohamed Moughamir"
  description="Senior Full-Stack Engineer. Experience in React, TypeScript, Bun, and AI integration."
>
  <main id="main-content" class="resume wrapper stack gap-15">
    <header class="resume-header">
      <p class="label">Curriculum Vitae</p>
      <h1 class="title">{profile.name}</h1>
      <p class="role">{profile.title}</p>
      <div class="contact-strip">
        <span>{profile.email}</span>
        <span>{profile.phone}</span>
        <span>{profile.location}</span>
      </div>
      <div class="cta-group">
        <a class="brutal-btn" href="/resume.pdf" download>Download PDF</a>
        <a class="ghost-link" href={profile.github}>GitHub</a>
      </div>
    </header>

    <section class="experience-section stack gap-8">
      <h2 class="section-title">Experience</h2>
      <div class="experience-grid">
        {experience.map((job) => (
          <article class="brutal-card">
            <div class="card-content">
              <header class="job-header">
                <h3>{job.company}</h3>
                <p class="job-meta">{job.role} // {job.dates}</p>
              </header>
              <ul class="highlights">
                {job.highlights.map((h) => <li>{h}</li>)}
              </ul>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="skills-grid">
      <div class="brutal-card">
        <div class="card-content">
          <p class="label">Frontend</p>
          <ul class="tag-cloud">
            {skills.frontend.map((s) => <li>{s}</li>)}
          </ul>
        </div>
      </div>
      <div class="brutal-card">
        <div class="card-content">
          <p class="label">Backend</p>
          <ul class="tag-cloud">
            {skills.backend.map((s) => <li>{s}</li>)}
          </ul>
        </div>
      </div>
    </section>

    <section class="edu-section stack gap-8">
      <h2 class="section-title">Education</h2>
      <div class="edu-grid">
        {education.map((edu) => (
          <article class="brutal-card">
            <div class="card-content">
              <h3>{edu.school}</h3>
              <p class="job-meta">{edu.detail} // {edu.dates}</p>
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>
  <ContactCTA />
</BaseLayout>

<style>
  .resume {
    padding: 6rem 0;
  }

  .label {
    color: var(--accent-regular);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 1rem;
    display: block;
  }

  .title {
    font-size: clamp(3rem, 10vw, 6rem);
    line-height: 0.9;
    margin-bottom: 1rem;
  }

  .role {
    font-size: 1.5rem;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--gray-100);
    margin-bottom: 2rem;
  }

  .contact-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--gray-300);
    text-transform: uppercase;
  }

  .cta-group {
    display: flex;
    gap: 2rem;
    margin-top: 3rem;
    align-items: center;
  }

  .ghost-link {
    color: var(--gray-0);
    font-weight: 800;
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 0.3em;
  }

  .section-title {
    font-size: 2.5rem;
    text-transform: uppercase;
    letter-spacing: -0.04em;
  }

  .experience-grid, .edu-grid {
    display: grid;
    gap: 2rem;
  }

  .job-header h3 {
    font-size: 1.5rem;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .job-meta {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--accent-regular);
    text-transform: uppercase;
  }

  .highlights {
    margin-top: 1.5rem;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .highlights li {
    font-weight: 600;
    color: var(--gray-200);
    padding-left: 1.5rem;
    position: relative;
    line-height: 1.4;
  }

  .highlights li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--accent-regular);
  }

  .skills-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    list-style: none;
    padding: 0;
  }

  .tag-cloud li {
    padding: 0.4rem 0.8rem;
    border: 1px solid var(--gray-0);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
  }
</style>
