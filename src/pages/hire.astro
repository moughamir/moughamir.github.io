---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Icon from "../components/Icon.astro";

const encodedEmail = btoa("moughamir@gmail.com");

const services = [
  {
    title: "Full-Time Role",
    desc: "Senior or lead engineer who owns the product end-to-end. I don't wait for tickets — I find the problems and ship the fixes.",
    price: "EMEA Remote"
  },
  {
    title: "Contract Project",
    desc: "From zero to production or from broken to stable. I take ownership of the product, not just the tasks.",
    price: "3-6 Month Engagement"
  },
  {
    title: "Rescue Sprint",
    desc: "Technical debt piling up? Site falling apart? I stabilize, clean up, and get things working again in 48-72h focused bursts.",
    price: "Flat Fee"
  }
];

const reasons = [
  "10+ Years Shipping Web Products",
  "AI-First Workflow (Bun, MCP, Gemini)",
  "EMEA Timezone / Remote Ready",
  "Clear Communication, No Runaround",
  "I Solve Problems, Then Move On"
];
---

<BaseLayout
  title="Hire Mohamed Moughamir — Senior Full-Stack Engineer"
  description="Senior Full-Stack and AI Engineer for EMEA remote, contract, or full-time roles."
>
  <main id="main-content" class="hire-page wrapper stack gap-20">
    <header class="aggressive-hero">
      <p class="eyebrow">Availability: Open for Q3 2026</p>
      <h1 class="title">Your next product needs<br/>an owner, not just a coder.</h1>
      <p class="lede">
        I take products from idea to production — frontend, backend, infrastructure, AI. 10+ years of full-stack ownership across startups and product teams.
      </p>
      <div class="cta-group">
        <a 
          href="javascript:void(0)" 
          data-email={encodedEmail} 
          onclick="location.href='mailto:'+atob(this.dataset.email)+'?subject=Engineering+Opportunity&body=Hi+Mohamed,+I+found+you+via+your+portfolio.'"
          class="brutal-btn hero-cta"
        >
          LET'S TALK
        </a>
      </div>
    </header>

    <section class="reasons-strip">
      <ul class="reason-list">
        {reasons.map((r) => (
          <li><Icon icon="strategy" size="1.2em" /> {r}</li>
        ))}
      </ul>
    </section>

    <section class="services-grid">
      <h2 class="section-title">HOW I HELP</h2>
      <div class="grid">
        {services.map((s) => (
          <article class="brutal-card service-card">
            <div class="card-content">
              <p class="price-tag">{s.price}</p>
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="brutal-card final-offer">
      <div class="card-content centered">
        <p class="label">Direct Access</p>
        <h2>WORK DIRECTLY WITH ME.</h2>
        <p class="final-text">
          No middlemen. Send me your problem, repo link, or brief — I usually respond within a few hours.
        </p>
        <div class="cta-row">
          <a 
            href="javascript:void(0)" 
            data-email={encodedEmail} 
            onclick="location.href='mailto:'+atob(this.dataset.email)+'?src=hire'"
            class="brutal-btn"
          >
            SEND AN EMAIL
          </a>
          <a href="https://linkedin.com/in/moughamir" target="_blank" rel="noopener noreferrer" class="ghost-link">
            LINKEDIN
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .hire-page {
    padding: 8rem 0;
  }

  .aggressive-hero {
    text-align: center;
  }

  .eyebrow {
    color: var(--accent-regular);
    font-family: var(--font-mono);
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .title {
    font-size: clamp(2.5rem, 10vw, 6.5rem);
    line-height: 1.05;
    font-weight: 800;
    letter-spacing: -0.05em;
    margin-bottom: 2.5rem;
  }

  .lede {
    font-size: 1.5rem;
    color: var(--gray-200);
    max-width: 45ch;
    margin-inline: auto;
    font-weight: 600;
    line-height: 1.3;
  }

  .hero-cta {
    font-size: 1.25rem;
    padding: 1.5rem 3rem;
    margin-top: 3rem;
  }

  .reasons-strip {
    background: var(--gray-0);
    color: var(--gray-999);
    padding: 3rem;
    margin: 0 -1.5rem;
  }

  .reason-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 3rem;
  }

  .reason-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
  }

  .section-title {
    font-size: 3rem;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    margin-bottom: 3rem;
    text-align: center;
  }

  .grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  }

  .service-card h3 {
    font-size: 1.75rem;
    text-transform: uppercase;
    margin-bottom: 1rem;
    line-height: 1.1;
  }

  .service-card p {
    font-weight: 500;
    color: var(--gray-300);
    line-height: 1.5;
  }

  .price-tag {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 800;
    color: var(--accent-regular);
    text-transform: uppercase;
    margin-bottom: 1rem;
    display: block;
  }

  .final-offer {
    background: var(--gray-0);
    color: var(--gray-999);
    margin-top: 4rem;
  }

  .final-text {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 3rem;
    max-width: 40ch;
  }

  .centered {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .cta-row {
    display: flex;
    gap: 2.5rem;
    align-items: center;
  }

  .ghost-link {
    color: var(--gray-999);
    font-weight: 800;
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 0.3em;
  }

  .label {
    color: var(--accent-regular);
    font-family: var(--font-mono);
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  @media (min-width: 60rem) {
    .reasons-strip {
      margin: 0;
    }
  }
</style>
