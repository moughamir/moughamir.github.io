---
import { getCollection } from "astro:content";

import BaseLayout from "../layouts/BaseLayout.astro";
import ContactCTA from "../components/ContactCTA.astro";
import PortfolioPreview from "../components/PortfolioPreview.astro";
import Hero from "../components/Hero.astro";

const projects = (await getCollection("work")).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

// Assign bento variants: first = wide, second = tall, rest cycle default/tall
const bentoProjects = projects.map((p, i) => {
  if (i === 0) return { project: p, variant: "wide" as const };
  if (i === 1) return { project: p, variant: "tall" as const };
  return {
    project: p,
    variant: (i % 2 === 0 ? "default" : "tall") as "default" | "tall",
  };
});
---

<BaseLayout
  title="Selected Work — Mohamed Moughamir"
  description="Selected projects from Mohamed Moughamir: web products, open-source tools, and AI infrastructure. Senior full-stack developer working with React, TypeScript, and Bun."
>
  <div class="stack gap-20">
    <main id="main-content" class="wrapper stack gap-8">
      <Hero
        title="Selected Work"
        tagline="Web products, open-source tools, and AI infrastructure — the things I've built and shipped."
        align="start"
      />
      <div class="bento-grid">
        {
          bentoProjects.map(({ project, variant }) => (
            <PortfolioPreview project={project} variant={variant} />
          ))
        }
      </div>
    </main>
    <ContactCTA />
  </div>
</BaseLayout>

<style>
  .bento-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    list-style: none;
    padding: 0;
  }

  @media (min-width: 50em) {
    .bento-grid {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
  }
</style>
