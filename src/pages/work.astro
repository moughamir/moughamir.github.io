---
import { getCollection } from "astro:content";

import BaseLayout from "../layouts/BaseLayout.astro";
import ContactCTA from "../components/ContactCTA.astro";
import PortfolioPreview from "../components/PortfolioPreview.astro";
import Hero from "../components/Hero.astro";
import Grid from "../components/Grid.astro";

const projects = (await getCollection("work")).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
---

<BaseLayout
  title="Selected Work — Mohamed Moughamir"
  description="Selected work and project signals from Mohamed Moughamir: web showcases, open-source experiments, developer education concepts, and practical product engineering. Senior full-stack developer focused on React, TypeScript, and AI-assisted delivery."
>
  <div class="stack gap-20">
    <main id="main-content" class="wrapper stack gap-8">
      <Hero
        title="Selected Work"
        tagline="A focused set of project signals: web showcases, developer education concepts, open-source experiments, and practical product engineering."
        align="start"
      />
      <Grid variant="offset">
        {
          projects.map((project) => (
            <li>
              <PortfolioPreview project={project} />
            </li>
          ))
        }
      </Grid>
    </main>
    <ContactCTA />
  </div>
</BaseLayout>
