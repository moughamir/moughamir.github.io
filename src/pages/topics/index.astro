---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import pseoData from "../../data/pseo.json";

const blogEntries = await getCollection("blog");
const workEntries = await getCollection("work");

const allTags = new Set();
[...blogEntries, ...workEntries].forEach((entry) => {
    entry.data.tags?.forEach((tag) => allTags.add(tag));
});

pseoData.comparisons.forEach(c => c.tags.forEach(t => allTags.add(t)));
pseoData.blueprints.forEach(b => b.tags.forEach(t => allTags.add(t)));

const sortedTags = Array.from(allTags).sort();

const pillars = [
    {
        number: "1",
        title: "AI Engineering & Production Workflows",
        description: "Moving past the wrapper hype to build reliable, production-grade AI infrastructure.",
        points: [
            { label: "Deterministic Output", text: "Strategies for grounding LLMs and handling structured data validation." },
            { label: "Agentic Orchestration", text: "Designing autonomous workflows that don't loop endlessly or waste compute." },
            { label: "Cost & Energy Efficiency", text: "Building minimal, energy-conscious background layers and architectures." },
        ],
    },
    {
        number: "2",
        title: "Model Context Protocol (MCP) & Knowledge Systems",
        description: "Bridging the gap between developmental runtime environments and local cognitive architecture.",
        points: [
            { label: "Obsidian MCP", text: "Extending local, markdown-based knowledge graphs (PARA/Zettelkasten) into executable tools for LLMs." },
            { label: "Contextual Framing", text: "How to structure deep technical context so AI agents can make better decisions with less token waste." },
        ],
    },
    {
        number: "3",
        title: "Open Source & Pragmatic Tooling",
        description: "Building minimalist, high-performance utilities from source, focusing on security, speed, and zero bloat.",
        points: [
            { label: "Rust & Minimal Daemons", text: "Event-driven tools (like structured NDJSON file watchers) built for speed." },
            { label: "Distroless & Containerization", text: "Hardening CI/CD pipelines by stripping away everything but the executable." },
        ],
    },
    {
        number: "4",
        title: "Startup Execution & Real-World Shipping",
        description: "The mechanics of taking an idea from a scrappy MVP to a functional system without burying yourself in technical debt.",
        points: [
            { label: "Velocity Over Perfection", text: "Tactical lessons on narrowing project scope to ship value on day one." },
            { label: "Legacy Rescues", text: "The unglamorous, highly profitable art of stepping into broken enterprise systems or WordPress wrecks and stabilizing them." },
        ],
    },
];
---

<BaseLayout
    title="Topics | Mohamed Moughamir"
    description="What I build and what I write about: AI systems, MCP, open source tooling, and production SaaS architecture."
>
    <main id="main-content" class="wrapper stack gap-8">
        <Hero
            title="What I Build. What I Write About."
            tagline=""
            align="start"
        />

        <section class="intro-section">
            <p class="intro-text">
                I don't optimize for frameworks, and I don't track vanity metrics. I build useful things, fast.
            </p>
            <p class="intro-text">
                On my <a href="https://moughamir.substack.com" target="_blank" rel="noopener noreferrer">Substack</a>, I document the exact engineering principles, architectural patterns, and execution strategies used to ship these projects under real-world constraints.
            </p>
            <p class="intro-text">
                If you are navigating the gap between high-tech complexity and actual business results, these are the core domains I break down:
            </p>
        </section>

        <section class="pillars-section stack gap-8">
            {pillars.map((pillar) => (
                <article class="pillar-item">
                    <h3 class="pillar-number">{pillar.number}. {pillar.title}</h3>
                    <p class="pillar-desc">{pillar.description}</p>
                    <ul class="pillar-points">
                        {pillar.points.map((point) => (
                            <li><strong>{point.label}:</strong> {point.text}</li>
                        ))}
                    </ul>
                </article>
            ))}
        </section>

        <hr class="divider" />

        <section class="thesis-section">
            <blockquote class="thesis-quote">
                <p><strong>Outcomes &gt; Frameworks.</strong></p>
                <p><strong>Value &gt; Complexity.</strong></p>
                <p><strong>Judgment &gt; Code Volume.</strong></p>
            </blockquote>
        </section>

        <section class="cta-section">
            <p class="cta-text">
                If this approach to engineering resonates with you, you should join the publication. No growth hacks, no marketing noise. Just the raw logs of a builder working at the edge of AI and software architecture.
            </p>
            <div class="cta-row">
                <a href="https://moughamir.substack.com" class="brutal-btn" target="_blank" rel="noopener noreferrer">
                    SUBSCRIBE TO THE SUBSTACK
                </a>
                <span class="cta-separator">•</span>
                <a href="https://github.com/moughamir" class="ghost-link" target="_blank" rel="noopener noreferrer">
                    EXPLORE THE CODE ON GITHUB
                </a>
            </div>
        </section>

        <section class="tags-section stack gap-4">
            <h2 class="section-title">Browse by Tag</h2>
            <div class="topics-grid">
                {sortedTags.map((tag) => (
                    <a href={`/topics/${tag.toLowerCase()}/`} class="tag-chip">
                        {tag}
                    </a>
                ))}
            </div>
        </section>
    </main>
</BaseLayout>

<style>
    .intro-section {
        max-width: 65ch;
    }

    .intro-text {
        font-size: 1.1rem;
        font-weight: 500;
        color: var(--gray-300);
        line-height: 1.7;
        margin-bottom: 1.25rem;
    }

    .intro-text :global(a) {
        color: var(--link-color);
        text-decoration: underline;
        text-underline-offset: 0.2em;
        font-weight: 700;
    }

    .intro-text :global(a:hover) {
        color: var(--accent-dark);
    }

    .pillars-section {
        max-width: 65ch;
    }

    .pillar-item {
        margin-bottom: 1.5rem;
    }

    .pillar-number {
        font-size: 1.25rem;
        margin-bottom: 0.5rem;
    }

    .pillar-desc {
        color: var(--gray-300);
        font-weight: 500;
        line-height: 1.6;
        margin-bottom: 0.75rem;
    }

    .pillar-points {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }

    .pillar-points li {
        color: var(--gray-300);
        font-size: 0.95rem;
        font-weight: 500;
        line-height: 1.6;
        padding-left: 1rem;
        position: relative;
    }

    .pillar-points li::before {
        content: "—";
        position: absolute;
        left: 0;
        color: var(--accent-regular);
    }

    .pillar-points li :global(strong) {
        color: var(--gray-0);
        font-weight: 700;
    }

    .divider {
        border: none;
        border-top: 2px solid var(--gray-0);
        margin: 2rem 0;
    }

    .thesis-quote {
        border-left: 3px solid var(--accent-regular);
        padding-left: 1.5rem;
        margin: 0;
    }

    .thesis-quote p {
        font-family: var(--font-brand);
        font-size: clamp(1.1rem, 2.5vw, 1.5rem);
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: -0.02em;
        line-height: 1.4;
        color: var(--gray-0);
        margin: 0 0 0.25rem 0;
    }

    .cta-section {
        max-width: 65ch;
    }

    .cta-text {
        font-size: 1.05rem;
        font-weight: 500;
        color: var(--gray-300);
        line-height: 1.7;
        margin-bottom: 1.5rem;
    }

    .cta-row {
        display: flex;
        gap: 1rem;
        align-items: center;
        flex-wrap: wrap;
    }

    .cta-separator {
        color: var(--gray-400);
        font-size: 1.2rem;
    }

    .ghost-link {
        color: var(--gray-0);
        font-weight: 800;
        text-transform: uppercase;
        text-decoration: underline;
        text-underline-offset: 0.3em;
        font-family: var(--font-brand);
        font-size: 0.9rem;
    }

    .ghost-link:hover {
        color: var(--accent-regular);
    }

    .section-title {
        font-size: 2rem;
        text-transform: uppercase;
        letter-spacing: -0.04em;
    }

    .topics-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
    }

    .tag-chip {
        display: inline-block;
        padding: 0.4rem 0.8rem;
        border: 1px solid var(--gray-0);
        font-family: var(--font-mono);
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        text-decoration: none;
        color: var(--gray-0);
        background: var(--gray-999);
        transition: background 0.1s, color 0.1s;
    }

    .tag-chip:hover {
        background: var(--gray-0);
        color: var(--gray-999);
    }
</style>
