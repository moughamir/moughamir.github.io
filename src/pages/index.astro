---
import BaseLayout from "../layouts/BaseLayout.astro";

const proof = [
  { value: "10+", label: "years building for web, product, and business" },
  { value: "249", label: "public GitHub repositories across experiments and apps" },
  { value: "3", label: "working languages: Arabic, French, English" },
  { value: "48–72h", label: "delivery window for focused rescue sprints" },
];

const capabilities = [
  {
    title: "Full-stack product delivery",
    body: "React, TypeScript, Node.js, PHP, Python, databases, APIs, and pragmatic deployment choices. I can move from idea to shipped web product without losing the business context.",
  },
  {
    title: "Rescue and modernization",
    body: "Stabilize broken websites, improve mobile UX, repair forms, clean WordPress/PHP stacks, and turn unclear codebases into something maintainable.",
  },
  {
    title: "AI-assisted automation",
    body: "Small internal tools, lead capture flows, reporting dashboards, scraping, email/WhatsApp workflows, and agent-assisted development loops.",
  },
];

const projects = [
  {
    title: "Obsidian MCP Plugin",
    type: "AI / Obsidian / Agent-native Development",
    body: "A high-performance Model Context Protocol (MCP) server providing AI tools with direct, semantic access to an Obsidian vault for agent-native application development. My most popular tool with active community contributions.",
    href: "https://github.com/moughamir/obsidian-mcp-plugin",
  },
  {
    title: "Anaqio AI Fashion Platform",
    type: "Bun Workspaces / AI / Monorepo",
    body: "Designed and built a full-stack AI fashion platform, demonstrating Bun monorepo architecture, scalable backend, and AI integration for complex product logic.",
    href: "https://github.com/moughamir/platform",
  },
];

const principles = [
  "Ship the smallest useful version first.",
  "Make the interface obvious before making it clever.",
  "Treat business constraints as engineering inputs.",
  "Use AI as leverage, not as a substitute for judgment.",
];
---

<BaseLayout
  title="Mohamed Moughamir — Senior Full-Stack Developer"
  description="Senior full-stack developer in Morocco building practical web products with React, TypeScript, Node.js, PHP, Python, and AI-assisted delivery. Available for contract and full-time work."
>
  <main id="main-content" class="home wrapper">
    <section class="hero-section">
      <div class="hero-container">
        <div class="hero-left">
          <p class="eyebrow">Bouskoura / Casablanca · Morocco · Remote-ready</p>
          <h1>I build things that ship and scale.</h1>
          <p class="lede">
            Senior full-stack engineer with 10+ years. I move fast, write clean code, and deliver products—not just features. From React dashboards to PHP rescues to AI-assisted workflows, I get useful work shipped.
          </p>
          <div class="cta-group">
            <a class="btn-primary" href="javascript:void(0)" data-email="bW91Z2hhbWlyQGdtYWlsLmNvbQ==" onclick="location.href='mailto:'+atob(this.dataset.email)">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              Hire me
            </a>
            <a class="btn-ghost" href="https://linkedin.com/in/moughamir" target="_blank" rel="noopener noreferrer">LinkedIn</a>
            <a class="btn-ghost" href="https://github.com/moughamir" target="_blank" rel="noopener noreferrer">GitHub</a>
            <a class="btn-ghost" href="https://youtube.com/@moughamir" target="_blank" rel="noopener noreferrer">YouTube</a>
            <a class="btn-ghost" href="/feed.xml">Podcast</a>
          </div>
        </div>
        <div class="hero-right">
          <div class="availability-badge">
            <span class="status-dot"></span>
            <span>Available now</span>
          </div>
          <p class="badge-sub">Full-time · Contract · Rescue sprints</p>
          <p class="badge-detail">React/TypeScript · Node.js · PHP · Python · AI workflows</p>
        </div>
      </div>
    </section>

    <section class="proof-grid" aria-label="Proof points">
      {proof.map((item) => (
        <article>
          <strong>{item.value}</strong>
          <span>{item.label}</span>
        </article>
      ))}
    </section>

    <section class="section-block">
      <div class="section-heading">
        <span class="small-label">What I can do this week</span>
        <h2>Useful work, shipped fast.</h2>
      </div>
      <div class="cards three">
        {capabilities.map((item) => (
          <article class="card">
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section-block split">
      <div class="section-heading sticky-heading">
        <span class="small-label">Selected proof</span>
        <h2>Recent signals and projects.</h2>
        <p>
          My GitHub shows breadth; this portfolio now focuses the story: full-stack execution, product sense, and practical technical experimentation.
        </p>
      </div>
      <div class="project-list">
        {projects.map((project) => (
          <a class="project-card" href={project.href}>
            <span>{project.type}</span>
            <h3>{project.title}</h3>
            <p>{project.body}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="section-block principle-panel">
      <div>
        <span class="small-label">How I work</span>
        <h2>Calm execution under real constraints.</h2>
      </div>
      <ul>
        {principles.map((principle) => <li>{principle}</li>)}
      </ul>
    </section>

    <section class="final-cta">
      <p class="small-label">Need a builder who can start now?</p>
      <h2>Let’s make the next 72 hours useful.</h2>
      <p>
        Send me the problem, the current link/repo if one exists, and what “fixed” means. I’ll reply with a practical next step.
      </p>
      <div class="cta-row centered">
        <a class="button primary" href="javascript:void(0)" data-email="bW91Z2hhbWlyQGdtYWlsLmNvbQ==" onclick="location.href='mailto:'+atob(this.dataset.email)">moughamir@gmail.com</a>
        <a class="button" href="/about/">More about me</a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .home {
    display: flex;
    flex-direction: column;
    gap: 5rem;
    padding-bottom: 5rem;
  }

  .hero-section {
    padding-top: 3rem;
  }

  .hero-container {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  @media (min-width: 48rem) {
    .hero-container {
      flex-direction: row;
      align-items: flex-start;
      justify-content: space-between;
      gap: 4rem;
    }
    .hero-left {
      max-width: 36rem;
    }
    .hero-right {
      flex-shrink: 0;
      padding-top: 0.5rem;
    }
  }

  .eyebrow {
    color: var(--gray-500);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .hero-left h1 {
    color: var(--gray-0);
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 1.05;
  }

  .lede {
    max-width: 60ch;
    margin-top: 1.5rem;
    color: var(--gray-400);
    font-size: clamp(1rem, 2vw, 1.2rem);
    line-height: 1.6;
  }

  .cta-group {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: var(--gray-0);
    color: var(--gray-999);
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    border-radius: 0.5rem;
    transition: transform 160ms ease, box-shadow 160ms ease;
  }

  .btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(255,255,255,0.15);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1rem;
    color: var(--gray-400);
    font-weight: 500;
    font-size: 0.9rem;
    text-decoration: none;
    border-radius: 0.5rem;
    border: 1px solid var(--gray-800);
    transition: color 160ms ease, border-color 160ms ease;
  }

  .btn-ghost:hover {
    color: var(--gray-0);
    border-color: var(--gray-600);
  }

  .availability-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: var(--gray-900);
    border: 1px solid var(--gray-800);
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--gray-0);
  }

  .status-dot {
    display: inline-block;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: #16a34a;
    box-shadow: 0 0 0 3px rgba(22, 163, 74, 0.15);
  }

  .badge-sub {
    margin-top: 0.75rem;
    color: var(--gray-500);
    font-size: 0.85rem;
  }

  .badge-detail {
    margin-top: 0.35rem;
    color: var(--gray-600);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .proof-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .proof-grid article {
    padding: 1rem;
  }

  .proof-grid strong {
    display: block;
    color: var(--gray-0);
    font-size: clamp(2rem, 5vw, 3.2rem);
    letter-spacing: -0.07em;
    line-height: 1;
  }

  .proof-grid span {
    display: block;
    margin-top: 0.5rem;
    color: var(--gray-500);
    font-size: 0.95rem;
  }

  .section-block {
    display: grid;
    gap: 1.5rem;
  }

  .section-heading h2,
  .principle-panel h2,
  .final-cta h2 {
    max-width: 14ch;
    margin-top: 0.4rem;
    color: var(--gray-0);
    font-size: clamp(2.25rem, 6vw, 4rem);
    letter-spacing: -0.065em;
    line-height: 0.98;
  }

  .section-heading p {
    max-width: 42ch;
    margin-top: 1rem;
    color: var(--gray-500);
  }

  .cards {
    display: grid;
    gap: 1rem;
  }

  .card {
    padding: 1.25rem;
  }

  .card h3,
  .project-card h3 {
    color: var(--gray-0);
    font-size: 1.35rem;
    letter-spacing: -0.035em;
  }

  .card p,
  .project-card p,
  .final-cta p {
    margin-top: 0.8rem;
    color: var(--gray-500);
    line-height: 1.65;
  }

  .project-list {
    display: grid;
    gap: 1rem;
  }

  .project-card {
    display: block;
    padding: 1.25rem;
    color: inherit;
    text-decoration: none;
    transition: transform 160ms ease, box-shadow 160ms ease;
  }

  .project-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--card-shadow-strong);
  }

  .project-card span {
    display: block;
    margin-bottom: 0.6rem;
    color: var(--gray-500);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  .principle-panel {
    display: grid;
    gap: 2rem;
    padding: 1.5rem;
  }

  .principle-panel ul {
    display: grid;
    gap: 0.75rem;
    padding: 0;
    list-style: none;
  }

  .principle-panel li {
    padding: 1rem;
    border-radius: 0.75rem;
    color: var(--gray-0);
    background: var(--gray-950);
    box-shadow: var(--border-shadow);
  }

  .final-cta {
    padding: clamp(2rem, 7vw, 5rem);
    text-align: center;
  }

  .final-cta h2 {
    max-width: 13ch;
    margin-inline: auto;
  }

  .final-cta p:not(.small-label) {
    max-width: 56ch;
    margin-inline: auto;
  }

  @media (min-width: 48rem) {
    .hero-grid {
      grid-template-columns: minmax(0, 1fr) 24rem;
      align-items: end;
    }

    .proof-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .cards.three {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .split {
      grid-template-columns: 0.75fr 1fr;
      align-items: start;
    }

    .sticky-heading {
      position: sticky;
      top: 2rem;
    }

    .principle-panel {
      grid-template-columns: 0.8fr 1fr;
      align-items: start;
      padding: 2rem;
    }
  }
</style>
