---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";

const proof = [
  { value: "10+", label: "years building for web, product, and business" },
  { value: "250+", label: "public repos on GitHub" },
  { value: "3", label: "working languages: Arabic, French, English" },
  { value: "290", label: "commits on obsidian-mcp-plugin" },
];

const capabilities = [
  {
    title: "Full-stack product delivery",
    body: "React, TypeScript, Node.js, PHP, Python, databases, APIs, and pragmatic deployment choices. I can move from idea to shipped web product without losing the business context.",
  },
  {
    title: "Rescue and modernization",
    body: "Stabilize broken websites, improve mobile UX, repair forms, clean WordPress/PHP stacks, and turn unclear codebases into something maintainable.",
  },
  {
    title: "AI-assisted automation",
    body: "Small internal tools, lead capture flows, reporting dashboards, scraping, email/WhatsApp workflows, and agent-assisted development loops.",
  },
];

const projects = [
  {
    title: "Anaqio AI Fashion Platform",
    type: "Bun Workspaces / AI / Monorepo",
    body: "Full-stack AI fashion platform turning flat lay product photos into photorealistic campaign visuals. Bun monorepo, precision-first AI pipeline, MCP tools, and production infrastructure.",
    href: "/work/anaqio-platform/",
  },
  {
    title: "Obsidian MCP Plugin",
    type: "AI / MCP / Obsidian / Open Source",
    body: "A high-performance MCP server giving AI tools direct, graph-aware access to an Obsidian vault. Hybrid SQL/vector search, 50ms tool response, active community adoption.",
    href: "/work/obsidian-mcp-plugin/",
  },
];

const principles = [
  "Ship the smallest useful version first.",
  "Make the interface obvious before making it clever.",
  "Treat business constraints as engineering inputs.",
  "Use AI as leverage, not as a substitute for judgment.",
];
---

<BaseLayout
  title="Mohamed Moughamir — Senior Software Engineer"
  description="Senior full-stack developer in Morocco building practical web products with React, TypeScript, Node.js, PHP, Python, and AI-assisted delivery."
>
  <main id="main-content" class="home wrapper">
    <section class="hero-section">
      <div class="hero-container">
        <p class="eyebrow">Bouskoura · Morocco · Remote-ready</p>
        <h1 class="title">I build things that ship and scale.</h1>
        <p class="lede">
          Senior full-stack and AI product engineer using TypeScript, Bun, React, PHP/Python, and MCP. I ship fast, write clean code, and deliver products — not just features.
        </p>
        <div class="cta-group">
          <a class="brutal-btn" href="javascript:void(0)" data-email="bW91Z2hhbWlyQGdtYWlsLmNvbQ==" onclick="location.href='mailto:'+atob(this.dataset.email)">
            Hire me
          </a>
          <a class="btn-ghost" href="https://github.com/moughamir" target="_blank" rel="noopener noreferrer">GitHub</a>
          <a class="btn-ghost" href="https://linkedin.com/in/moughamir" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        </div>
      </div>
    </section>

    <section class="proof-grid" aria-label="Proof points">
      {proof.map((item) => (
        <article class="proof-card">
          <strong>{item.value}</strong>
          <span>{item.label}</span>
        </article>
      ))}
    </section>

    <section class="bento">
      <div class="bento-label">
        <span class="small-label">What I do</span>
        <h2>Useful work, shipped fast.</h2>
      </div>

      <div class="bento-grid">
        {capabilities.map((cap) => (
          <article class="brutal-card">
            <div class="card-content">
              <h3>{cap.title}</h3>
              <p>{cap.body}</p>
            </div>
          </article>
        ))}

        <a class="brutal-card brutal-wide" href={projects[0].href}>
          <div class="card-content">
            <span class="project-tag">{projects[0].type}</span>
            <h3>{projects[0].title}</h3>
            <p>{projects[0].body}</p>
          </div>
        </a>

        <a class="brutal-card" href={projects[1].href}>
          <div class="card-content">
            <span class="project-tag">{projects[1].type}</span>
            <h3>{projects[1].title}</h3>
            <p>{projects[1].body}</p>
          </div>
        </a>

        <article class="brutal-card">
          <div class="card-content">
            <span class="small-label">How I work</span>
            <h3>Calm execution under real constraints.</h3>
            <ul class="principle-list">
              {principles.map((p) => <li>{p}</li>)}
            </ul>
          </div>
        </article>
      </div>
    </section>

    <section class="final-cta brutal-card">
      <div class="card-content centered">
        <p class="small-label">Need a builder who can start now?</p>
        <h2>Let’s make the next sprint useful.</h2>
        <p>
          Send me the problem, the current link or repo, and what success should look like.
        </p>
        <div class="cta-row centered">
          <a class="brutal-btn" href="javascript:void(0)" data-email="bW91Z2hhbWlyQGdtYWlsLmNvbQ==" onclick="location.href='mailto:'+atob(this.dataset.email)">Send an email</a>
          <a class="btn-ghost" href="/about/">More about me</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .home {
    display: flex;
    flex-direction: column;
    gap: 8rem;
    padding-bottom: 8rem;
  }

  .hero-section {
    padding: 6rem 0;
  }

  .eyebrow {
    color: var(--accent-regular);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .title {
    font-size: clamp(3rem, 10vw, 6rem);
    line-height: 0.9;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    color: var(--gray-0);
    max-width: 15ch;
  }

  .lede {
    max-width: 50ch;
    margin-top: 2rem;
    color: var(--gray-200);
    font-size: 1.25rem;
    line-height: 1.5;
    font-weight: 500;
  }

  .cta-group {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-top: 3rem;
    align-items: center;
  }

  .btn-ghost {
    color: var(--gray-0);
    font-weight: 800;
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 0.3em;
  }

  .proof-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  }

  .proof-card strong {
    display: block;
    font-size: 3rem;
    font-weight: 900;
    line-height: 1;
    color: var(--gray-0);
  }

  .proof-card span {
    display: block;
    margin-top: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--gray-300);
    text-transform: uppercase;
  }

  .bento-label h2 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    text-transform: uppercase;
    line-height: 1;
    margin: 0.5rem 0 3rem;
  }

  .bento-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
  }

  .brutal-card {
    border: 2px solid var(--gray-0);
    background: var(--gray-999);
    text-decoration: none;
    color: inherit;
    transition: transform 0.1s, box-shadow 0.1s;
  }

  .brutal-card:hover {
    transform: translate(-4px, -4px);
    box-shadow: 4px 4px 0 0 var(--accent-regular);
  }

  .card-content {
    padding: 2.5rem;
  }

  .card-content.centered {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .project-tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--accent-regular);
    text-transform: uppercase;
    margin-bottom: 1rem;
    display: block;
  }

  .principle-list {
    margin-top: 2rem;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .principle-list li {
    font-weight: 700;
    color: var(--gray-100);
    padding-left: 1.5rem;
    position: relative;
  }

  .principle-list li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--accent-regular);
  }

  .small-label {
    font-family: var(--font-mono);
    font-weight: 800;
    text-transform: uppercase;
    font-size: 0.8rem;
    color: var(--gray-400);
  }

  .final-cta {
    margin-top: 4rem;
  }

  .cta-row {
    display: flex;
    gap: 2rem;
    margin-top: 3rem;
    align-items: center;
  }

  @media (min-width: 60rem) {
    .bento-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .brutal-wide {
      grid-column: span 2;
    }
  }
</style>
