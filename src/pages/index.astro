---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import ContactCTA from "../components/ContactCTA.astro";

const proof = [
  { value: "10+", label: "years shipping web products" },
  { value: "3", label: "products shipped from idea to production" },
  { value: "3", label: "working languages: Arabic, French, English" },
];

const capabilities = [
  {
    title: "Full-stack product delivery",
    body: "React, TypeScript, Node.js, PHP, Python — databases, APIs, and deployment. I go from idea to shipped product without losing sight of what the business actually needs.",
  },
  {
    title: "Rescue and modernization",
    body: "Broken websites, bad mobile UX, failing forms, tangled WordPress/PHP stacks. I stabilize what's falling apart and make it maintainable.",
  },
  {
    title: "AI-assisted automation",
    body: "Internal tools, lead capture flows, dashboards, scraping, email/WhatsApp workflows. I use AI to remove repetitive work — not to replace thinking.",
  },
];

const projects = [
  {
    title: "Anaqio AI Fashion Platform",
    type: "Bun Workspaces / AI / Monorepo",
    body: "Turns flat-lay product photos into photorealistic campaign visuals. Bun monorepo, AI pipeline, MCP tools — the whole thing runs in production.",
    href: "/work/anaqio-platform/",
  },
  {
    title: "Obsidian MCP Plugin",
    type: "AI / MCP / Obsidian / Open Source",
    body: "Lets AI tools talk directly to an Obsidian vault. Hybrid SQL/vector search, 50ms response times, and a growing community using it daily.",
    href: "/work/obsidian-mcp-plugin/",
  },
];

const principles = [
  "Ship the smallest useful thing first.",
  "Make the interface obvious, then make it clever.",
  "Business constraints are engineering inputs.",
  "AI is leverage, not a substitute for judgment.",
];
---

<BaseLayout
  title="Mohamed Moughamir — Senior Software Engineer"
  description="Senior full-stack developer in Morocco building web products with React, TypeScript, Node.js, PHP, Python, and AI."
>
  <main id="main-content" class="home wrapper">
    <section class="hero-section">
      <div class="hero-container">
        <p class="eyebrow">Bouskoura · Morocco · Remote-ready</p>
        <h1 class="title">I take products from idea to production.</h1>
        <p class="lede">
          Senior full-stack engineer. I own the whole product — frontend, backend, infrastructure, AI integration. Not just the code that ships, but the product that works.
        </p>
        <div class="cta-group">
          <a class="brutal-btn" href="/hire/">Let's talk</a>
          <a class="btn-ghost" href="https://github.com/moughamir" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
      </div>
    </section>

    <section class="proof-grid" aria-label="Proof points">
      {proof.map((item) => (
        <article class="proof-card">
          <strong>{item.value}</strong>
          <span>{item.label}</span>
        </article>
      ))}
    </section>

    <section class="bento">
      <div class="bento-label">
        <span class="small-label">What I do</span>
        <h2>What I do.</h2>
      </div>

      <div class="bento-grid">
        {capabilities.map((cap) => (
          <article class="brutal-card">
            <div class="card-content">
              <h3>{cap.title}</h3>
              <p>{cap.body}</p>
            </div>
          </article>
        ))}

        <a class="brutal-card brutal-wide" href={projects[0].href}>
          <div class="card-content">
            <span class="project-tag">{projects[0].type}</span>
            <h3>{projects[0].title}</h3>
            <p>{projects[0].body}</p>
          </div>
        </a>

        <a class="brutal-card" href={projects[1].href}>
          <div class="card-content">
            <span class="project-tag">{projects[1].type}</span>
            <h3>{projects[1].title}</h3>
            <p>{projects[1].body}</p>
          </div>
        </a>

        <article class="brutal-card">
          <div class="card-content">
            <span class="small-label">How I work</span>
            <h3>How I work.</h3>
            <ul class="principle-list">
              {principles.map((p) => <li>{p}</li>)}
            </ul>
          </div>
        </article>
      </div>
    </section>

    <ContactCTA />
  </main>
</BaseLayout>

<style>
  .home {
    display: flex;
    flex-direction: column;
    gap: 8rem;
    padding-bottom: 8rem;
  }

  .hero-section {
    padding: 6rem 0;
  }

  .eyebrow {
    color: var(--accent-regular);
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .title {
    font-size: clamp(2.5rem, 9vw, 5.5rem);
    line-height: 1.1;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: var(--gray-0);
    max-width: 15ch;
  }

  .lede {
    max-width: 50ch;
    margin-top: 2rem;
    color: var(--gray-200);
    font-size: 1.25rem;
    line-height: 1.5;
    font-weight: 500;
  }

  .cta-group {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-top: 3rem;
    align-items: center;
  }

  .btn-ghost {
    color: var(--gray-0);
    font-weight: 800;
    text-transform: uppercase;
    text-decoration: none;
    text-underline-offset: 0.3em;
    transition: color 0.1s;
  }

  .btn-ghost:hover {
    color: var(--accent-regular);
    text-decoration: underline;
  }

  .proof-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  }

  .proof-card strong {
    display: block;
    font-size: 3rem;
    font-weight: 800;
    line-height: 1;
    color: var(--gray-0);
  }

  .proof-card span {
    display: block;
    margin-top: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--gray-300);
    text-transform: uppercase;
  }

  .bento-label h2 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    text-transform: uppercase;
    line-height: 1;
    margin: 0.5rem 0 3rem;
  }

  .bento-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
  }

  .brutal-card {
    border: 2px solid var(--gray-0);
    background: var(--gray-999);
    text-decoration: none;
    color: inherit;
    transition: transform 0.1s, box-shadow 0.1s;
  }

  .brutal-card:hover {
    transform: translate(-4px, -4px);
    box-shadow: 4px 4px 0 0 var(--accent-regular);
  }

  .card-content {
    padding: 2.5rem;
  }

  .card-content.centered {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .project-tag {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--accent-regular);
    text-transform: uppercase;
    margin-bottom: 1rem;
    display: block;
  }

  .principle-list {
    margin-top: 2rem;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .principle-list li {
    font-weight: 700;
    color: var(--gray-100);
    padding-left: 1.5rem;
    position: relative;
  }

  .principle-list li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--accent-regular);
  }

  .small-label {
    font-family: var(--font-body);
    font-weight: 800;
    text-transform: uppercase;
    font-size: 0.8rem;
    color: var(--gray-400);
  }

  @media (min-width: 60rem) {
    .bento-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .brutal-wide {
      grid-column: span 2;
    }
  }
</style>
